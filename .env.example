# Claude Agent Runtime API configuration
#
# Copy this file to `.env` with `make setup`, then edit values for your
# deployment. Docker Compose reads this same file for port interpolation and
# passes it into the container as runtime environment variables.

# ---------------------------------------------------------------------------
# Docker build mirrors
# ---------------------------------------------------------------------------

# Debian apt mirror used while building the image. Defaults to Aliyun.
APT_MIRROR=https://mirrors.aliyun.com/debian

# Debian security mirror used while building the image. Defaults to Aliyun.
APT_SECURITY_MIRROR=https://mirrors.aliyun.com/debian-security

# Python package index used by pip inside the image. Defaults to Aliyun PyPI.
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
PIP_TRUSTED_HOST=mirrors.aliyun.com

# npm registry used by npm commands in the image. npmmirror is the current
# Taobao npm mirror service.
NPM_REGISTRY=https://registry.npmmirror.com

# ---------------------------------------------------------------------------
# API service
# ---------------------------------------------------------------------------

# Host interface used by uvicorn inside the container. Keep 0.0.0.0 for Docker.
API_HOST=0.0.0.0

# Port listened to inside the container.
API_PORT=8080

# Port exposed on the host by docker-compose.yml.
HOST_PORT=8080

# Host directory mounted to WORKSPACE_DIR.
HOST_WORKSPACE_MOUNT=./workspace

# Host directory mounted to DATA_DIR.
HOST_DATA_MOUNT=./data

# Host directory mounted to /root so Claude Code sees native paths:
# /root/.claude and /root/.claude.json.
HOST_CLAUDE_ROOT_MOUNT=./claude-root

# Optional bearer token for API endpoints. Empty disables API-key enforcement.
API_KEY=change-me

# Optional base URL used by local helper scripts. Leave commented to derive it
# from HOST_PORT automatically.
# API_BASE=http://localhost:8080

# ---------------------------------------------------------------------------
# Model provider
# ---------------------------------------------------------------------------

# Preferred generic provider key. The runtime maps it to ANTHROPIC_API_KEY for
# Claude Agent SDK / Claude Code.
MODEL_PROVIDER_API_KEY=sk-ant-xxxx

# Optional provider base URL. Use this for Anthropic-compatible gateways,
# proxies, or private model-provider endpoints. The runtime maps it to
# ANTHROPIC_BASE_URL for Claude Agent SDK / Claude Code.
# MODEL_PROVIDER_API_URL=https://api.anthropic.com

# Compatibility aliases. Use these instead of MODEL_PROVIDER_* if your
# deployment standardizes on Anthropic variable names.
# ANTHROPIC_API_KEY=sk-ant-xxxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ---------------------------------------------------------------------------
# Container filesystem and Claude config locations
# ---------------------------------------------------------------------------

# Workspace mounted into the container. Claude runs with this as cwd.
WORKSPACE_DIR=/workspace

# Writable API runtime data directory for sessions, uploads, and outputs.
DATA_DIR=/data

# Claude home mounted into the container.
CLAUDE_HOME=/root/.claude

# Advanced: redirect Claude Code's config/state directory. Leave commented for
# native Claude Code behavior: user config in /root/.claude and global state in
# /root/.claude.json. When set, Claude Code writes .claude.json and transcripts
# under this directory instead.
# CLAUDE_CONFIG_DIR=/data/claude-config

# Advanced: extra settings JSON passed like Claude Code's --settings flag.
# Leave commented to use native user/project/local settings precedence.
# CLAUDE_SETTINGS_PATH=/workspace/.claude/settings.json

# Advanced: explicit MCP config passed like --mcp-config. Leave commented to
# let Claude Code discover .mcp.json and ~/.claude.json using native behavior.
# CLAUDE_MCP_CONFIG_PATH=/workspace/.mcp.json

# ---------------------------------------------------------------------------
# Claude Agent model and execution controls
# ---------------------------------------------------------------------------

# Default model used when requests do not provide a model override.
AGENT_MODEL=claude-sonnet-4-5

# Optional fallback model.
# FALLBACK_MODEL=claude-haiku-4-5

# Optional comma-separated tool preset/list for ClaudeAgentOptions.tools.
# Leave commented unless you need the SDK-level tools option.
# CLAUDE_TOOLS=

# Per-request allowed_tools defaults when the request omits allowed_tools.
DEFAULT_ALLOWED_TOOLS=Read,Grep,Glob

# Per-request disallowed_tools defaults when the request omits disallowed_tools.
DEFAULT_DISALLOWED_TOOLS=Bash,WebFetch,WebSearch

# Claude permission mode used when the request omits permission_mode.
# Typical values: default, acceptEdits, plan, bypassPermissions, dontAsk, auto.
PERMISSION_MODE=dontAsk

# Optional default subagent used when requests omit agent.
# DEFAULT_AGENT=security-triage

# Optional comma-separated default skills used when requests omit skills.
# DEFAULT_SKILLS=threat-triage,ocsf-mapping

# Skill loading mode used when the request omits skills_mode.
# Values: default, all, none.
DEFAULT_SKILLS_MODE=default

# Max Claude Agent turns used when the request omits max_turns.
MAX_TURNS=8

# Optional USD budget cap for one SDK query.
# MAX_BUDGET_USD=1.00

# Optional system prompt text appended to the Claude Code preset for every run.
# CLAUDE_SYSTEM_APPEND=Always write concise final answers.

# ---------------------------------------------------------------------------
# Claude Agent advanced SDK options
# ---------------------------------------------------------------------------

# Load .claude/agents/*.md into ClaudeAgentOptions.agents. Keep false for
# native Claude Code discovery; set true only for SDK-only explicit injection.
ENABLE_PROGRAMMATIC_AGENTS=false

# Resume Claude SDK sessions when an API session already has an SDK session id.
ENABLE_SDK_SESSION_RESUME=true

# Enable the built-in Bash safety hook/can_use_tool policy.
ENABLE_POLICY_HOOKS=true

# Include Claude hook events in SDK messages.
INCLUDE_HOOK_EVENTS=true

# Include partial messages from the SDK stream.
INCLUDE_PARTIAL_MESSAGES=false

# Validate MCP config strictly in the SDK.
STRICT_MCP_CONFIG=false

# Optional Claude CLI executable path.
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# Optional comma-separated extra directories exposed to Claude.
# CLAUDE_ADD_DIRS=/data/uploads,/data/outputs

# Optional comma-separated Claude beta flags.
# CLAUDE_BETAS=context-1m-2025-08-07

# Optional permission prompt tool name.
# PERMISSION_PROMPT_TOOL_NAME=

# Optional Claude SDK user identifier.
# CLAUDE_USER=

# Comma-separated Claude setting sources. Default mirrors Claude Code:
# user -> /root/.claude/settings.json
# project -> /workspace/.claude/settings.json
# local -> /workspace/.claude/settings.local.json
CLAUDE_SETTING_SOURCES=user,project,local

# Optional thinking controls supported by the SDK.
# MAX_THINKING_TOKENS=4096
# EFFORT=medium

# Enable SDK file checkpointing.
ENABLE_FILE_CHECKPOINTING=false

# Session store flush mode. Values: batched, eager.
SESSION_STORE_FLUSH=batched

# SDK load timeout in milliseconds.
LOAD_TIMEOUT_MS=60000

# Optional SDK max buffer size in bytes.
# MAX_BUFFER_SIZE=10485760

# Arbitrary extra environment variables passed only to the Claude SDK process.
# Use this for provider-specific knobs such as Bedrock, Vertex, proxy, or
# enterprise gateway settings.
CLAUDE_ENV_JSON={}

# Arbitrary extra Claude CLI args passed through ClaudeAgentOptions.extra_args.
# Example: {"verbose": null}
CLAUDE_EXTRA_ARGS_JSON={}
