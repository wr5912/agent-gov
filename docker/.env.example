# Claude Agent Runtime API 配置
#
# 运行 `make setup` 会把本文件复制为 `docker/.env`。Docker Compose 使用
# `docker/.env` 做端口插值，并把其中的变量传入容器运行时。

# ---------------------------------------------------------------------------
# Docker 构建镜像源
# ---------------------------------------------------------------------------

# Python 基础镜像。默认使用官方镜像；如果内部仓库提供国内镜像，可在这里覆盖。
PYTHON_IMAGE=python:3.11-slim

# Debian apt 主仓库镜像，默认阿里云。
APT_MIRROR=https://mirrors.aliyun.com/debian

# Debian security 仓库镜像，默认阿里云。
APT_SECURITY_MIRROR=https://mirrors.aliyun.com/debian-security

# Python 包索引。uv/pip 均通过该地址拉取包，默认阿里云 PyPI。
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
PIP_TRUSTED_HOST=mirrors.aliyun.com

# npm registry，默认 npmmirror，即淘宝 npm 镜像服务。
NPM_REGISTRY=https://registry.npmmirror.com

# ---------------------------------------------------------------------------
# API 服务
# ---------------------------------------------------------------------------

# 容器内 uvicorn 监听地址。Docker 中保持 0.0.0.0。
API_HOST=0.0.0.0

# 容器内 API 端口。
API_PORT=8080

# 宿主机暴露端口。API_PORT 小于 10000，默认遵循项目规则：
# 50000 + 8080 = 58080。
HOST_PORT=58080

# 挂载到容器 WORKSPACE_DIR 的宿主机目录。相对路径基于 docker/。
HOST_WORKSPACE_MOUNT=./volume/workspace

# 挂载到容器 DATA_DIR 的宿主机目录。相对路径基于 docker/。
HOST_DATA_MOUNT=./volume/data

# 挂载到容器 /root 的宿主机目录，使 Claude Code 看到原生路径：
# /root/.claude 和 /root/.claude.json。相对路径基于 docker/。
HOST_CLAUDE_ROOT_MOUNT=./volume/claude-root

# API 鉴权 Bearer token。留空表示关闭 API key 校验。
API_KEY=change-me

# 本地脚本使用的 API 基础 URL。通常无需设置，会根据 HOST_PORT 自动推导。
# API_BASE=http://localhost:58080

# ---------------------------------------------------------------------------
# 模型提供商
# ---------------------------------------------------------------------------

# 通用模型提供商 API key。运行时会映射为 Claude Agent SDK / Claude Code
# 使用的 ANTHROPIC_API_KEY。
MODEL_PROVIDER_API_KEY=sk-ant-xxxx

# 模型提供商 API URL。用于 Anthropic 兼容网关、代理或私有模型服务。
# 运行时会映射为 ANTHROPIC_BASE_URL。
# MODEL_PROVIDER_API_URL=https://api.anthropic.com

# 兼容别名。如果部署规范要求 Anthropic 原生变量名，可使用下面两项。
# ANTHROPIC_API_KEY=sk-ant-xxxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ---------------------------------------------------------------------------
# 容器文件系统与 Claude 配置路径
# ---------------------------------------------------------------------------

# 容器内 workspace。Claude Code 以此为 cwd。
WORKSPACE_DIR=/workspace

# 容器内 API 运行数据目录，用于 sessions、uploads、outputs 等。
DATA_DIR=/data

# 容器内 Claude home。
CLAUDE_HOME=/root/.claude

# 高级选项：重定向 Claude Code 的配置/状态目录。默认保持注释，使用原生路径：
# 用户配置在 /root/.claude，全局状态在 /root/.claude.json。
# 设置后 Claude Code 会把 .claude.json 和 transcripts 写到该目录下。
# CLAUDE_CONFIG_DIR=/data/claude-config

# 高级选项：额外 settings JSON，等价于 Claude Code 的 --settings。
# 默认保持注释，使用原生 user/project/local settings 优先级。
# CLAUDE_SETTINGS_PATH=/workspace/.claude/settings.json

# 高级选项：显式 MCP 配置，等价于 --mcp-config。
# 默认保持注释，让 Claude Code 原生发现 .mcp.json 和 ~/.claude.json。
# CLAUDE_MCP_CONFIG_PATH=/workspace/.mcp.json

# ---------------------------------------------------------------------------
# Claude Agent 模型与执行控制
# ---------------------------------------------------------------------------

# 请求未指定 model 时使用的默认模型。
AGENT_MODEL=claude-sonnet-4-5

# 可选 fallback 模型。
# FALLBACK_MODEL=claude-haiku-4-5

# 可选 ClaudeAgentOptions.tools 预设/列表。通常保持注释。
# CLAUDE_TOOLS=

# 请求未指定 allowed_tools 时使用的默认允许工具。
DEFAULT_ALLOWED_TOOLS=Read,Grep,Glob

# 请求未指定 disallowed_tools 时使用的默认禁用工具。
DEFAULT_DISALLOWED_TOOLS=Bash,WebFetch,WebSearch

# 请求未指定 permission_mode 时使用的 Claude 权限模式。
# 常见值：default、acceptEdits、plan、bypassPermissions、dontAsk、auto。
PERMISSION_MODE=dontAsk

# 请求未指定 agent 时使用的默认 subagent。
# DEFAULT_AGENT=security-triage

# 请求未指定 skills 时使用的默认 skills，逗号分隔。
# DEFAULT_SKILLS=threat-triage,ocsf-mapping

# 请求未指定 skills_mode 时使用的 skill 加载模式。
# 可选值：default、all、none。
DEFAULT_SKILLS_MODE=default

# 请求未指定 max_turns 时使用的最大 Agent 轮数。
MAX_TURNS=8

# 单次 SDK query 的可选预算上限，单位美元。
# MAX_BUDGET_USD=1.00

# 每次运行都会追加到 Claude Code preset system prompt 的文本。
# CLAUDE_SYSTEM_APPEND=Always write concise final answers.

# ---------------------------------------------------------------------------
# Claude Agent SDK 高级选项
# ---------------------------------------------------------------------------

# 是否把 .claude/agents/*.md 显式注入 ClaudeAgentOptions.agents。
# 默认 false，使用 Claude Code 原生发现机制。
ENABLE_PROGRAMMATIC_AGENTS=false

# API session 已存在 SDK session id 时，是否使用 Claude SDK resume。
ENABLE_SDK_SESSION_RESUME=true

# 是否启用内置 Bash 安全 hook / can_use_tool 策略。
ENABLE_POLICY_HOOKS=true

# 是否在 SDK messages 中包含 Claude hook events。
INCLUDE_HOOK_EVENTS=true

# 是否包含 SDK stream 的 partial messages。
INCLUDE_PARTIAL_MESSAGES=false

# 是否严格校验 MCP 配置。
STRICT_MCP_CONFIG=false

# 可选 Claude CLI 可执行文件路径。
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# 可选额外目录，逗号分隔，暴露给 Claude。
# CLAUDE_ADD_DIRS=/data/uploads,/data/outputs

# 可选 Claude beta flags，逗号分隔。
# CLAUDE_BETAS=context-1m-2025-08-07

# 可选 permission prompt tool 名称。
# PERMISSION_PROMPT_TOOL_NAME=

# 可选 Claude SDK user 标识。
# CLAUDE_USER=

# Claude setting sources，默认匹配 Claude Code：
# user -> /root/.claude/settings.json
# project -> /workspace/.claude/settings.json
# local -> /workspace/.claude/settings.local.json
CLAUDE_SETTING_SOURCES=user,project,local

# 可选 thinking 控制。
# MAX_THINKING_TOKENS=4096
# EFFORT=medium

# 是否启用 SDK file checkpointing。
ENABLE_FILE_CHECKPOINTING=false

# Session store 刷盘模式。可选值：batched、eager。
SESSION_STORE_FLUSH=batched

# SDK 加载超时，单位毫秒。
LOAD_TIMEOUT_MS=60000

# 可选 SDK 最大 buffer size，单位字节。
# MAX_BUFFER_SIZE=10485760

# 仅传给 Claude SDK 子进程的额外环境变量。
# 适合配置 Bedrock、Vertex、代理或企业网关等 provider-specific 参数。
CLAUDE_ENV_JSON={}

# 透传给 ClaudeAgentOptions.extra_args 的额外 Claude CLI 参数。
# 示例：{"verbose": null}
CLAUDE_EXTRA_ARGS_JSON={}
