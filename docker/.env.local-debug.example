# Host/PyCharm local debug overrides. Copy to docker/.env.local-debug.
#
# AppSettings reads this file after docker/.env and docker/.env.local when the
# backend runs directly on the host. Docker Compose does not load this file, so
# container deployment keeps using ${HOME}/volume-agent-runtime.

RUNTIME_VOLUME_MODE=local-debug
HOST_RUNTIME_VOLUME_ROOT=/tmp/local-debug-volume-agent-runtime

# Host debug runs uvicorn directly, so bind to localhost and use the unshifted
# API port. Frontend/browser smoke can still target this port explicitly.
API_HOST=127.0.0.1
API_PORT=8080
HOST_PORT=8080

# Runtime host paths. These intentionally do not reuse ${HOME}/volume-agent-runtime.
WORKSPACE_DIR=${HOST_RUNTIME_VOLUME_ROOT}/main-workspace
MAIN_WORKSPACE_DIR=${HOST_RUNTIME_VOLUME_ROOT}/main-workspace
ATTRIBUTION_ANALYZER_WORKSPACE_DIR=${HOST_RUNTIME_VOLUME_ROOT}/attribution-analyzer-workspace
PROPOSAL_GENERATOR_WORKSPACE_DIR=${HOST_RUNTIME_VOLUME_ROOT}/proposal-generator-workspace
EXECUTION_OPTIMIZER_WORKSPACE_DIR=${HOST_RUNTIME_VOLUME_ROOT}/execution-optimizer-workspace
EVAL_CASE_GOVERNOR_WORKSPACE_DIR=${HOST_RUNTIME_VOLUME_ROOT}/eval-case-governor-workspace
REGRESSION_IMPACT_ANALYZER_WORKSPACE_DIR=${HOST_RUNTIME_VOLUME_ROOT}/regression-impact-analyzer-workspace
DATA_DIR=${HOST_RUNTIME_VOLUME_ROOT}/data

CLAUDE_ROOT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/main
MAIN_CLAUDE_ROOT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/main
ATTRIBUTION_ANALYZER_CLAUDE_ROOT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/attribution-analyzer
PROPOSAL_GENERATOR_CLAUDE_ROOT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/proposal-generator
EXECUTION_OPTIMIZER_CLAUDE_ROOT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/execution-optimizer
EVAL_CASE_GOVERNOR_CLAUDE_ROOT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/eval-case-governor
REGRESSION_IMPACT_ANALYZER_CLAUDE_ROOT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/regression-impact-analyzer
CLAUDE_HOME=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/main/.claude

# Config-mapping display fields for host-run paths.
HOST_WORKSPACE_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/main-workspace
HOST_ATTRIBUTION_ANALYZER_WORKSPACE_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/attribution-analyzer-workspace
HOST_PROPOSAL_GENERATOR_WORKSPACE_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/proposal-generator-workspace
HOST_EXECUTION_OPTIMIZER_WORKSPACE_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/execution-optimizer-workspace
HOST_EVAL_CASE_GOVERNOR_WORKSPACE_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/eval-case-governor-workspace
HOST_REGRESSION_IMPACT_ANALYZER_WORKSPACE_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/regression-impact-analyzer-workspace
HOST_DATA_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/data
HOST_CLAUDE_ROOT_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/main
HOST_ATTRIBUTION_ANALYZER_CLAUDE_ROOT_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/attribution-analyzer
HOST_PROPOSAL_GENERATOR_CLAUDE_ROOT_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/proposal-generator
HOST_EXECUTION_OPTIMIZER_CLAUDE_ROOT_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/execution-optimizer
HOST_EVAL_CASE_GOVERNOR_CLAUDE_ROOT_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/eval-case-governor
HOST_REGRESSION_IMPACT_ANALYZER_CLAUDE_ROOT_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/regression-impact-analyzer

AGENT_GIT_WORKTREES_DIR=${HOST_RUNTIME_VOLUME_ROOT}/data/agent-governance/worktrees
AGENT_RELEASE_ARCHIVES_DIR=${HOST_RUNTIME_VOLUME_ROOT}/data/agent-governance/releases

# Host processes cannot resolve Docker service names such as http://langfuse-web:3000.
LANGFUSE_BASE_URL=http://localhost:53000
FRONTEND_RUNTIME_API_BASE=http://localhost:8080

# Optional host-local MCP override.
# CLAUDE_MCP_CONFIG_PATH=${HOST_RUNTIME_VOLUME_ROOT}/main-workspace/.mcp.local.json
# CLAUDE_ENV_JSON={"NO_PROXY":"localhost,127.0.0.1,host.docker.internal","no_proxy":"localhost,127.0.0.1,host.docker.internal"}
