# Host/PyCharm local debug environment. Copy to docker/.env.local-debug.
#
# Host-run Python processes read this file automatically. Docker Compose does
# not load this file. Keep Runtime/API/worker keys aligned with docker/.env.example;
# only host paths, ports, and localhost service URLs should differ.

LITELLM_LOCAL_MODEL_COST_MAP=True

# ---------------------------------------------------------------------------
# API service
# ---------------------------------------------------------------------------

API_HOST=0.0.0.0
LOG_LEVEL=debug
API_PORT=8080
HOST_PORT=8080

HOST_RUNTIME_VOLUME_ROOT=/tmp/local-debug-volume-agent-gov

HOST_WORKSPACE_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/main-workspace
HOST_GOVERNOR_WORKSPACE_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/governor-workspace
HOST_DATA_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/data
HOST_CLAUDE_ROOT_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/main
HOST_GOVERNOR_CLAUDE_ROOT_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/governor

AGENT_GIT_SERVICE_PROVIDER=local
AGENT_GIT_REPOSITORY_NAME=main-agent-config
AGENT_GIT_WORKTREES_DIR=${HOST_RUNTIME_VOLUME_ROOT}/data/agent-governance/worktrees
AGENT_RELEASE_ARCHIVES_DIR=${HOST_RUNTIME_VOLUME_ROOT}/data/agent-governance/releases

# Leave blank for unauthenticated local API debugging.
API_KEY=

FRONTEND_RUNTIME_API_BASE=http://localhost:8080
FRONTEND_RUNTIME_API_KEY=
FRONTEND_LANGFUSE_URL=http://localhost:53000

# ---------------------------------------------------------------------------
# Model provider
# ---------------------------------------------------------------------------

# Background Agent jobs do not reuse interactive Claude /login state. Configure
# these values in the private docker/.env.local-debug before running API/worker.
# vLLM 使用 vllm；Anthropic 兼容网关使用 anthropic_compatible。不要通过 URL
# 字符串推断 provider。
MODEL_PROVIDER_BACKEND=anthropic_compatible

MODEL_PROVIDER_API_KEY=

# 唯一真实模型服务 URL。vLLM 场景填写 base URL，例如 http://localhost:8000，
# 不带 /v1；LiteLLM sidecar 后端地址和 Claude Code ANTHROPIC_BASE_URL
# 均由 Runtime 派生，不新增 MODEL_PROVIDER_UPSTREAM_URL。
MODEL_PROVIDER_API_URL=

# vLLM 路由策略阈值和探测参数。版本事实只来自 {MODEL_PROVIDER_API_URL}/version；
# 禁止配置 MODEL_PROVIDER_VLLM_VERSION。
MODEL_PROVIDER_VLLM_SIDECAR_THRESHOLD=0.23.0
# Opt-in: default false (vLLM always routes via the LiteLLM sidecar). Only when true AND the probed vLLM
# version >= threshold does Claude Code talk to vLLM native /v1/messages directly (still gated by the
# capability probe; fail-closed with VLLM_DIRECT_CLAUDE_CODE_COMPAT_FAILED if the endpoint is incompatible).
MODEL_PROVIDER_VLLM_ALLOW_DIRECT=false
# 探测/能力门 HTTP 超时秒数。真实模型（如 27B）首 token 常 >3s，3 会被能力门误判超时永久阻断；vLLM 等本地模型建议 >=30。
MODEL_PROVIDER_PROBE_TIMEOUT_SECONDS=30
MODEL_PROVIDER_WARNING_TTL_SECONDS=300

# Compatible aliases for Anthropic-compatible direct deployments.
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=

# ---------------------------------------------------------------------------
# Host filesystem and Claude profile paths
# ---------------------------------------------------------------------------

WORKSPACE_DIR=${HOST_RUNTIME_VOLUME_ROOT}/main-workspace
MAIN_WORKSPACE_DIR=${HOST_RUNTIME_VOLUME_ROOT}/main-workspace
GOVERNOR_WORKSPACE_DIR=${HOST_RUNTIME_VOLUME_ROOT}/governor-workspace
DATA_DIR=${HOST_RUNTIME_VOLUME_ROOT}/data

CLAUDE_ROOT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/main
MAIN_CLAUDE_ROOT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/main
GOVERNOR_CLAUDE_ROOT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/governor
CLAUDE_HOME=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/main/.claude

# Claude Code 官方配置文件由各 profile workspace 自行发现：
# .mcp.json、.claude/settings.json、.claude/agents、.claude/skills 等。
# 后端不通过 SDK Options 接管 MCP、settings、权限、hooks、agents 或 skills。
MCP_SERVER_URL=http://localhost:58001/mcp

# ---------------------------------------------------------------------------
# Claude Agent model and execution controls
# ---------------------------------------------------------------------------

AGENT_MODEL=claude-sonnet-4-5

# FALLBACK_MODEL=claude-haiku-4-5

ENABLE_DSPY_OUTPUT_FORMATTER=true
DSPY_OUTPUT_FORMATTER_TIMEOUT_SECONDS=300
DSPY_OUTPUT_FORMATTER_MAX_RETRIES=1
DSPY_OUTPUT_FORMATTER_MAX_TOKENS=8192

# DSPY_OUTPUT_FORMATTER_MODEL=claude-sonnet-4-5

AGENT_JOB_WORKER_POLL_INTERVAL_SECONDS=2

# DEFAULT_AGENT=security-triage
# DEFAULT_SKILLS=threat-triage,ocsf-mapping
DEFAULT_SKILLS_MODE=default
MAX_TURNS=16
# MAX_BUDGET_USD=1.00
# CLAUDE_SYSTEM_APPEND=Always write concise final answers.

# ---------------------------------------------------------------------------
# Claude Agent SDK advanced options
# ---------------------------------------------------------------------------

ENABLE_SDK_SESSION_RESUME=true
ENABLE_FEEDBACK_DEBUG_EVIDENCE=true
INCLUDE_HOOK_EVENTS=true
INCLUDE_PARTIAL_MESSAGES=false

# CLAUDE_CLI_PATH=/usr/local/bin/claude
# CLAUDE_ADD_DIRS=${HOST_RUNTIME_VOLUME_ROOT}/data/uploads,${HOST_RUNTIME_VOLUME_ROOT}/data/outputs
# CLAUDE_BETAS=context-1m-2025-08-07
# PERMISSION_PROMPT_TOOL_NAME=
# CLAUDE_USER=

# MAX_THINKING_TOKENS=4096
# EFFORT=medium

ENABLE_FILE_CHECKPOINTING=false
SESSION_STORE_FLUSH=batched
LOAD_TIMEOUT_MS=60000
# MAX_BUFFER_SIZE=10485760

# ---------------------------------------------------------------------------
# Langfuse / OpenTelemetry runtime tracing
# ---------------------------------------------------------------------------

LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Host processes cannot resolve Docker service names such as http://langfuse-web:3000.
LANGFUSE_BASE_URL=http://localhost:53000
LANGFUSE_OTEL_ENDPOINT=
LANGFUSE_OTEL_SIGNALS=traces,metrics,logs
LANGFUSE_SERVICE_NAME=agent-gov-api
LANGFUSE_DEPLOYMENT_ENVIRONMENT=local
LANGFUSE_RESOURCE_ATTRIBUTES=
LANGFUSE_EXPORT_INTERVAL_MS=1000

# Extra environment passed only to Claude SDK child processes.
CLAUDE_ENV_JSON={"NO_PROXY":"localhost,127.0.0.1,host.docker.internal","no_proxy":"localhost,127.0.0.1,host.docker.internal"}

# Extra Claude CLI args passed through ClaudeAgentOptions.extra_args.
CLAUDE_EXTRA_ARGS_JSON={}
