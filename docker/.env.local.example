# Local-only overrides. Docker Compose loads this file after docker/.env when it exists.
# Copy this file to docker/.env.local and adjust HOST_RUNTIME_VOLUME_ROOT if needed.
# docker/.env.local is ignored by git. Keep container paths (/main-workspace, /data,
# /claude-roots/main) unless you are launching the backend directly on the host.

HOST_RUNTIME_VOLUME_ROOT=${HOME}/volume-agent-runtime

API_HOST=127.0.0.1
API_PORT=8080
HOST_PORT=8080

# Docker Compose should keep these container paths. For host/PyCharm debugging only,
# uncomment and change them to ${HOST_RUNTIME_VOLUME_ROOT}/main-workspace, /data and /claude-roots/main.
# WORKSPACE_DIR=${HOST_RUNTIME_VOLUME_ROOT}/main-workspace
# DATA_DIR=${HOST_RUNTIME_VOLUME_ROOT}/data
# CLAUDE_ROOT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/main

# These only affect config-mapping display fields.
HOST_WORKSPACE_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/main-workspace
HOST_DATA_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/data
HOST_CLAUDE_ROOT_MOUNT=${HOST_RUNTIME_VOLUME_ROOT}/claude-roots/main

# Host processes cannot resolve Docker service names such as http://langfuse-web:3000.
LANGFUSE_BASE_URL=http://localhost:53000

# Optional local MCP override. For Docker Compose, main profile automatically uses
# /main-workspace/.mcp.local.json if it exists, so this is usually unnecessary.
# For host/PyCharm debugging, point to ${HOST_RUNTIME_VOLUME_ROOT}/main-workspace/.mcp.local.json.
# CLAUDE_MCP_CONFIG_PATH=/main-workspace/.mcp.local.json
# CLAUDE_ENV_JSON={"NO_PROXY":"<host-ip>,localhost,127.0.0.1,host.docker.internal","no_proxy":"<host-ip>,localhost,127.0.0.1,host.docker.internal"}
