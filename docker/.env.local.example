# Local-only overrides for running the backend on the host, for example from PyCharm.
# Copy this file to docker/.env.local and replace PROJECT_ROOT with your local repo path.
# docker/.env.local is ignored by git and is loaded after docker/.env.

PROJECT_ROOT=/absolute/path/to/claude-agent-runtime

API_HOST=127.0.0.1
API_PORT=8080
HOST_PORT=8080

# AppSettings derives the other profile workspace/root paths from WORKSPACE_DIR and CLAUDE_ROOT.
WORKSPACE_DIR=${PROJECT_ROOT}/docker/volume/main-workspace
DATA_DIR=${PROJECT_ROOT}/docker/volume/data
CLAUDE_ROOT=${PROJECT_ROOT}/docker/volume/claude-roots/main

# These only affect config-mapping display fields.
HOST_WORKSPACE_MOUNT=${PROJECT_ROOT}/docker/volume/main-workspace
HOST_DATA_MOUNT=${PROJECT_ROOT}/docker/volume/data
HOST_CLAUDE_ROOT_MOUNT=${PROJECT_ROOT}/docker/volume/claude-roots/main

# Host processes cannot resolve Docker service names such as http://langfuse-web:3000.
LANGFUSE_BASE_URL=http://localhost:53000
