{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Read(./**)",
      "Read(/data/uploads/**)",
      "Read(/data/outputs/security-operations-expert/**)",
      "Glob",
      "Grep",
      "Skill",
      "Bash(jq *)",
      "Bash(date *)",
      "Bash(date)",
      "Bash(pwd)",
      "Bash(mkdir -p /data/outputs/security-operations-expert/**)",
      "Edit(/data/outputs/security-operations-expert/**)",
      "Write(/data/outputs/security-operations-expert/**)",
      "mcp__sec-ops__*"
    ],
    "ask": [],
    "deny": [
      "AskUserQuestion",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(/data/business-agents/security-operations-expert/claude-root/.claude.json)",
      "Read(/data/business-agents/security-operations-expert/claude-root/.claude/projects/**)",
      "Edit(./.mcp.json)",
      "Write(./.mcp.json)",
      "NotebookEdit(./.mcp.json)",
      "Edit(./CLAUDE.md)",
      "Write(./CLAUDE.md)",
      "NotebookEdit(./CLAUDE.md)",
      "Edit(./agent.yaml)",
      "Write(./agent.yaml)",
      "NotebookEdit(./agent.yaml)",
      "Edit(./.claude/**)",
      "Write(./.claude/**)",
      "NotebookEdit(./.claude/**)",
      "Edit(./hooks/**)",
      "Write(./hooks/**)",
      "NotebookEdit(./hooks/**)",
      "Bash(cat *claude-root*)",
      "Bash(head *claude-root*)",
      "Bash(tail *claude-root*)",
      "Bash(less *claude-root*)",
      "Bash(grep *claude-root*)",
      "Bash(cat *.claude/projects*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf /)",
      "Bash(:(){ :|:& };:*)",
      "Bash(curl *|sh*)",
      "Bash(wget *|sh*)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(http *)",
      "Bash(httpie *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(socat *)",
      "mcp__sec-ops__soc_api__create*",
      "mcp__sec-ops__soc_api__manual",
      "mcp__sec-ops__soc_api__execute",
      "mcp__sec-ops__soc_api__post_*",
      "mcp__sec-ops__soc_api__put_*",
      "mcp__sec-ops__soc_api__delete_*",
      "mcp__sec-ops__soc_api__patch_*",
      "mcp__sec-ops__soc_api__create_1",
      "mcp__sec-ops__soc_api__update*",
      "mcp__sec-ops__soc_api__delete*",
      "mcp__sec-ops__soc_api__upload*",
      "mcp__sec-ops__soc_api__cancel*",
      "mcp__sec-ops__soc_api__rollback"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/hooks/pre_tool_guard.py\"",
            "timeout": 10,
            "statusMessage": "检查安全运营动作风险"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/hooks/post_tool_audit.py\"",
            "async": true,
            "timeout": 10,
            "statusMessage": "记录安全运营工具调用审计摘要"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/hooks/session_start.py\"",
            "timeout": 5,
            "statusMessage": "加载安全运营会话提示"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": false,
    "filesystem": {
      "allowWrite": [
        "/data/outputs/security-operations-expert"
      ],
      "denyRead": [
        "./.env",
        "./secrets",
        "/data/business-agents/security-operations-expert/claude-root/.claude.json"
      ]
    },
    "network": {
      "allowedDomains": [
        "${SERVICE_HOST}",
        "${INTERNAL_DOMAIN}"
      ],
      "deniedDomains": []
    },
    "allowUnsandboxedCommands": false
  },
  "spinnerTipsOverride": {
    "excludeDefault": false,
    "tips": [
      "安全运营先区分事实、推断和行动。",
      "响应处置先查实 SOC 能力，再规划、再预演。",
      "高危处置动作需四要素：证据、审批、先 dry-run、回滚方案。",
      "Agent 只形成整本剧本候选；保存、SOC manual 执行（内含预检）和监控由 RO 状态机完成。"
    ]
  },
  "includeGitInstructions": false
}
