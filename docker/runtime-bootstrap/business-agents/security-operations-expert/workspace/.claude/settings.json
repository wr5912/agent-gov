{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Read(./**)",
      "Read(../../../uploads/**)",
      "Read(../../../outputs/security-operations-expert/**)",
      "Glob",
      "Grep",
      "Skill",
      "Bash(*)",
      "Bash(jq *)",
      "Bash(date *)",
      "Bash(date)",
      "Bash(pwd)",
      "Bash(mkdir -p ../../../outputs/security-operations-expert/**)",
      "Edit(./**)",
      "Write(./**)",
      "Write(../../../outputs/security-operations-expert/**)",
      "mcp__sec-ops__*"
    ],
    "ask": [
      "mcp__sec-ops__soc_api__create",
      "mcp__sec-ops__soc_api__manual"
    ],
    "deny": [
      "AskUserQuestion",
      "mcp__sec-ops__soc_api__execute",
      "mcp__sec-ops__soc_api__create_1",
      "mcp__sec-ops__soc_api__update*",
      "mcp__sec-ops__soc_api__delete*",
      "mcp__sec-ops__soc_api__upload*",
      "mcp__sec-ops__soc_api__cancel*",
      "mcp__sec-ops__soc_api__rollback*",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(../../*/claude-root/**)",
      "Read(../../../agent-governance/**)",
      "Read(../../../runtime.sqlite3*)",
      "Read(../claude-root/.claude.json)",
      "Read(../claude-root/.claude/projects/**)",
      "Bash(cat *claude-root*)",
      "Bash(head *claude-root*)",
      "Bash(tail *claude-root*)",
      "Bash(less *claude-root*)",
      "Bash(grep *claude-root*)",
      "Bash(cat *.claude/projects*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf /)",
      "Bash(:(){ :|:& };:*)",
      "Bash(curl *|sh*)",
      "Bash(wget *|sh*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/hooks/pre_tool_guard.py\"",
            "timeout": 10,
            "statusMessage": "Checking command safety"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/hooks/post_tool_audit.py\"",
            "async": true,
            "timeout": 10,
            "statusMessage": "记录安全运营工具调用审计摘要"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/hooks/session_start.py\"",
            "timeout": 5,
            "statusMessage": "加载安全运营会话提示"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "enableWeakerNestedSandbox": true,
    "filesystem": {
      "allowWrite": [
        "../../../outputs/security-operations-expert",
        "../../../transcripts"
      ],
      "denyRead": [
        "./.env",
        "./secrets",
        "../../*/claude-root/**",
        "../../../agent-governance/**",
        "../../../runtime.sqlite3*",
        "../claude-root/.claude.json"
      ]
    },
    "network": {
      "allowedDomains": [
        "localhost",
        "127.0.0.1",
        "host.docker.internal",
        "*.internal",
        "*.corp"
      ],
      "deniedDomains": []
    },
    "allowUnsandboxedCommands": false
  },
  "spinnerTipsOverride": {
    "excludeDefault": false,
    "tips": [
      "安全运营先区分事实、推断和行动。",
      "响应处置先查实 SOC 能力，再规划、再预演。",
      "高危处置动作需四要素：证据、审批、先 dry-run、回滚方案。",
      "执行完成不等于效果达成，必须做效果评估。"
    ]
  },
  "includeGitInstructions": false
}
