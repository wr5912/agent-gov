{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Read(./**)",
      "Read(../../../uploads/**)",
      "Read(../../../outputs/**)",
      "Glob",
      "Grep",
      "Skill",
      "Bash(jq *)",
      "Bash(date *)",
      "Bash(date)",
      "Bash(pwd)",
      "Bash(mkdir -p ../../../outputs/ai-soc-gap-analyzer/**)",
      "Write(../../../outputs/ai-soc-gap-analyzer/**)"
    ],
    "ask": [
      "Bash(*)",
      "mcp__*__*write*",
      "mcp__*__*update*",
      "mcp__*__*delete*",
      "mcp__*__*block*",
      "mcp__*__*isolate*",
      "mcp__*__*disable*",
      "mcp__*__*kill*",
      "mcp__*__*quarantine*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(../../*/claude-root/**)",
      "Read(../../../agent-governance/**)",
      "Read(../../../runtime.sqlite3*)",
      "Read(../claude-root/.claude.json)",
      "Read(../claude-root/.claude/projects/**)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf /)",
      "Bash(:(){ :|:& };:*)",
      "Bash(curl *|sh*)",
      "Bash(wget *|sh*)",
      "mcp__*__*write*",
      "mcp__*__*update*",
      "mcp__*__*delete*",
      "mcp__*__*execute*",
      "mcp__*__*submit*",
      "mcp__*__*block*",
      "mcp__*__*isolate*",
      "mcp__*__*disable*",
      "mcp__*__*kill*",
      "mcp__*__*quarantine*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/hooks/pre_tool_guard.py\"",
            "timeout": 10,
            "statusMessage": "Checking command safety"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": false,
    "enableWeakerNestedSandbox": true,
    "filesystem": {
      "allowWrite": [
        "../../../outputs/ai-soc-gap-analyzer"
      ],
      "denyRead": [
        "./.env",
        "./secrets",
        "../../*/claude-root/**",
        "../../../agent-governance/**",
        "../../../runtime.sqlite3*",
        "../claude-root/.claude.json"
      ]
    },
    "network": {
      "allowedDomains": [],
      "deniedDomains": []
    },
    "allowUnsandboxedCommands": false
  },
  "skillOverrides": {
    "ai-soc-gap-analysis": "user-invocable-only"
  },
  "spinnerTipsOverride": {
    "excludeDefault": false,
    "tips": [
      "AI SOC 差距评估先归类证据，再评分。",
      "没有证据支撑的能力分不能高估。",
      "建议行动优先补证据、补闭环和补验收用例。"
    ]
  },
  "includeGitInstructions": false
}
