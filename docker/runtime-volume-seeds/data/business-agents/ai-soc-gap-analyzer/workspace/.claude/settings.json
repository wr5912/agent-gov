{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Read(./**)",
      "Read(/data/uploads/**)",
      "Read(/data/outputs/**)",
      "Glob",
      "Grep",
      "Skill",
      "Bash(jq *)",
      "Bash(date *)",
      "Bash(date)",
      "Bash(pwd)",
      "Bash(mkdir -p /data/outputs/ai-soc-gap-analyzer/**)",
      "Write(/data/outputs/ai-soc-gap-analyzer/**)"
    ],
    "ask": [],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(/data/business-agents/ai-soc-gap-analyzer/claude-root/.claude.json)",
      "Read(/data/business-agents/ai-soc-gap-analyzer/claude-root/.claude/projects/**)",
      "Edit(./**)",
      "Write(./**)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf /)",
      "Bash(:(){ :|:& };:*)",
      "Bash(curl *|sh*)",
      "Bash(wget *|sh*)",
      "mcp__*__*write*",
      "mcp__*__*update*",
      "mcp__*__*delete*",
      "mcp__*__*execute*",
      "mcp__*__*submit*",
      "mcp__*__*block*",
      "mcp__*__*isolate*",
      "mcp__*__*disable*",
      "mcp__*__*kill*",
      "mcp__*__*quarantine*"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": false,
    "autoAllowBashIfSandboxed": false,
    "filesystem": {
      "allowWrite": [
        "/data/outputs/ai-soc-gap-analyzer"
      ],
      "denyRead": [
        "./.env",
        "./secrets",
        "/data/business-agents/ai-soc-gap-analyzer/claude-root/.claude.json"
      ]
    },
    "network": {
      "allowedDomains": [],
      "deniedDomains": []
    }
  },
  "skillOverrides": {
    "ai-soc-gap-analysis": "user-invocable-only"
  },
  "spinnerTipsOverride": {
    "excludeDefault": false,
    "tips": [
      "AI SOC 差距评估先归类证据，再评分。",
      "没有证据支撑的能力分不能高估。",
      "建议行动优先补证据、补闭环和补验收用例。"
    ]
  },
  "includeGitInstructions": false
}
