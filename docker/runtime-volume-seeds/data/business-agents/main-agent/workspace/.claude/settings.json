{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Read(./**)",
      "Glob",
      "Grep",
      "Skill",
      "Bash(python mcp_servers/**)",
      "Bash(python -m pytest *)",
      "Bash(jq *)",
      "Bash(date *)",
      "Bash(date)",
      "Bash(pwd)",
      "Bash(cat templates/**)",
      "Bash(mkdir -p /data/outputs/**)",
      "Bash(mkdir -p /data/reports/**)",
      "Write(/data/outputs/**)",
      "Write(/data/reports/**)",
      "mcp__sec-ops-data__*"
    ],
    "ask": [
      "Bash(*)",
      "Edit(./**)",
      "Write(./**)",
      "mcp__*__*write*",
      "mcp__*__*update*",
      "mcp__*__*delete*",
      "mcp__*__*block*",
      "mcp__*__*isolate*",
      "mcp__*__*disable*",
      "mcp__*__*kill*",
      "mcp__*__*quarantine*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(/data/business-agents/**/claude-root/**)",
      "Read(/data/agent-governance/**)",
      "Read(/data/runtime.sqlite3*)",
      "Read(/data/business-agents/main-agent/claude-root/.claude.json)",
      "Read(/data/business-agents/main-agent/claude-root/.claude/projects/**)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf /)",
      "Bash(:(){ :|:& };:*)",
      "Bash(curl *|sh*)",
      "Bash(wget *|sh*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/hooks/pre_tool_guard.py\"",
            "timeout": 10,
            "statusMessage": "Checking command safety"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/hooks/post_tool_audit.py\"",
            "async": true,
            "timeout": 10,
            "statusMessage": "记录工具调用审计摘要"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/hooks/session_start.py\"",
            "timeout": 5,
            "statusMessage": "加载安全运营会话提示"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": false,
    "enableWeakerNestedSandbox": false,
    "filesystem": {
      "allowWrite": [
        "/data/outputs",
        "/data/reports",
        "/data/transcripts",
        "./"
      ],
      "denyRead": [
        "./.env",
        "./secrets",
        "/data/business-agents/**/claude-root/**",
        "/data/agent-governance/**",
        "/data/runtime.sqlite3*",
        "/data/business-agents/main-agent/claude-root/.claude.json"
      ]
    },
    "network": {
      "allowedDomains": [
        "${SERVICE_HOST}",
        "${SERVICE_HOST}",
        "${INTERNAL_DOMAIN}",
        "${INTERNAL_DOMAIN}"
      ],
      "deniedDomains": []
    },
    "allowUnsandboxedCommands": false
  },
  "skillOverrides": {
    "policy-change": "user-invocable-only",
    "incident-response": "user-invocable-only"
  },
  "spinnerTipsOverride": {
    "excludeDefault": false,
    "tips": [
      "安全运营任务默认先收集证据，再给结论。",
      "生产处置动作需要审批、dry-run、回滚和验证。"
    ]
  },
  "includeGitInstructions": false
}
