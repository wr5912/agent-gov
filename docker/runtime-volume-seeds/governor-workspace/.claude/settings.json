{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Glob",
      "Grep"
    ],
    "ask": [],
    "deny": [
      "Write(/**)",
      "Edit(/**)",
      "MultiEdit(/**)",
      "NotebookEdit(/**)",
      "Bash(*)"
    ]
  },
  "includeGitInstructions": false
}
