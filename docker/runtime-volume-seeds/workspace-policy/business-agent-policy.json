{
  "version": "2026-07-13.4",
  "settings": {
    "permissions": {
      "defaultMode": "default",
      "disableBypassPermissionsMode": "disable",
      "deny": [
        "Read(/data/business-agents/**/claude-root/**)",
        "Read(/data/agent-governance/**)",
        "Read(/data/runtime.sqlite3*)",
        "Bash(rm -rf /*)",
        "Bash(rm -rf /)",
        "Bash(:(){ :|:& };:*)",
        "Bash(curl *|sh*)",
        "Bash(wget *|sh*)"
      ]
    },
    "hooks": {
      "PreToolUse": [
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "python \"$CLAUDE_PROJECT_DIR/hooks/pre_tool_guard.py\"",
              "timeout": 10,
              "statusMessage": "Checking command safety"
            }
          ]
        }
      ]
    },
    "sandbox": {
      "enabled": true,
      "failIfUnavailable": true,
      "autoAllowBashIfSandboxed": false,
      "filesystem": {
        "denyRead": [
          "/data/business-agents/**/claude-root/**",
          "/data/agent-governance/**",
          "/data/runtime.sqlite3*"
        ]
      },
      "allowUnsandboxedCommands": false
    }
  },
  "agentSettings": {
    "security-data-standardization-review": {
      "permissions": {
        "deny": [
          "mcp__*__*write*",
          "mcp__*__*update*",
          "mcp__*__*delete*",
          "mcp__*__*block*",
          "mcp__*__*isolate*",
          "mcp__*__*disable*",
          "mcp__*__*kill*",
          "mcp__*__*quarantine*",
          "mcp__*__*execute*",
          "mcp__*__*submit*",
          "mcp__*__*register*"
        ]
      }
    }
  }
}
