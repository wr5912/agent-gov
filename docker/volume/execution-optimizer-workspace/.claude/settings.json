{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read(/data/optimization-executions/**)",
      "Read(/data/optimization-tasks/**)",
      "Read(/data/agent-versions/main/**)",
      "Glob",
      "Grep"
    ],
    "ask": [],
    "deny": [
      "Write(/main-workspace/**)",
      "Edit(/main-workspace/**)",
      "Write(/claude-roots/main/**)",
      "Edit(/claude-roots/main/**)",
      "Read(/**/.env)",
      "Read(/**/credentials/**)",
      "Bash(*)"
    ]
  },
  "includeGitInstructions": false
}
