# Runtime API 设置弹窗的默认后端地址。
VITE_RUNTIME_API_BASE=http://localhost:58080

# Runtime API 设置弹窗的默认 API Key。Docker 服务由 docker/.env 注入。
VITE_RUNTIME_API_KEY=

# 顶部栏 Langfuse 按钮打开的浏览器地址。
VITE_LANGFUSE_URL=http://localhost:53000

# 改进事项/反馈治理类长耗时动作的浏览器请求超时秒数。
VITE_GOVERNANCE_AGENT_TIMEOUT_SECONDS=300

# 仅 Vite dev server 使用，决定 /api 代理到哪里。
VITE_DEV_PROXY_TARGET=http://localhost:58080
