{
  "name": "agent-gov-ui",
  "private": true,
  "version": "2.8.7",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "generate:api-types": "../.venv/bin/python ../scripts/export_openapi.py --output /tmp/agent-gov-openapi.json && openapi-typescript /tmp/agent-gov-openapi.json -o src/types/api.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "verify:design-parity": "cd .. && node scripts/verify_improvement_ui_design_parity.mjs",
    "verify:improvement-decision": "cd .. && node scripts/verify_improvement_decision_ui.mjs",
    "verify:asset-registry": "cd .. && node scripts/verify_asset_registry.mjs",
    "verify:claude-user-input": "cd .. && node scripts/verify_claude_user_input_ui.mjs",
    "verify:remote-api-base": "cd .. && node scripts/verify_remote_api_base.mjs",
    "verify:message-actions-browser": "cd .. && node scripts/verify_message_actions_browser.mjs"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/view": "^6.43.4",
    "@uiw/react-codemirror": "^4.25.10",
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.60.0"
  }
}
