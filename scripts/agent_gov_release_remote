#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  agent_gov_release_remote deploy --release-root <path> --release-id <id>
  agent_gov_release_remote rollback --release-root <path> --release-id <id>
  agent_gov_release_remote status --release-root <path>
  agent_gov_release_remote diagnose --release-root <path> --release-id <id>

This helper is invoked on the Docker Compose target by
deploy_agent_gov_to_host. It never reads GitHub credentials.
USAGE
}

COMMAND=${1:-}
if [[ -z "$COMMAND" || "$COMMAND" == "-h" || "$COMMAND" == "--help" ]]; then
  usage
  exit 0
fi
shift

RELEASE_ROOT=""
RELEASE_ID=""
while (( $# )); do
  case "$1" in
    --release-root)
      RELEASE_ROOT=${2:-}
      shift 2
      ;;
    --release-id)
      RELEASE_ID=${2:-}
      shift 2
      ;;
    *)
      printf '[release-remote] ERROR: unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

[[ -n "$RELEASE_ROOT" ]] || { printf '[release-remote] ERROR: --release-root is required\n' >&2; exit 1; }
RELEASE_ROOT=$(python3 -c 'import os, sys; print(os.path.abspath(os.path.expanduser(sys.argv[1])))' "$RELEASE_ROOT")
RELEASES_DIR="$RELEASE_ROOT/releases"
SHARED_DIR="$RELEASE_ROOT/shared"
SHARED_ENV="$SHARED_DIR/docker.env"
CURRENT_LINK="$RELEASE_ROOT/current"
LOCK_FILE="$RELEASE_ROOT/.deploy.lock"

log() {
  printf '[release-remote] %s\n' "$*"
}

die() {
  printf '[release-remote] ERROR: %s\n' "$*" >&2
  exit 1
}

validate_release_id() {
  [[ "$1" =~ ^[A-Za-z0-9._-]+$ ]] || die "invalid release id: $1"
}

release_dir() {
  validate_release_id "$1"
  printf '%s/%s' "$RELEASES_DIR" "$1"
}

release_id_from_path() {
  local path=${1:-}
  [[ -n "$path" ]] || return 0
  basename "$(readlink -f "$path")"
}

read_env() {
  local key=$1
  local default=$2
  local value
  value=$(awk -F= -v key="$key" '
    $1 == key {
      sub(/^[^=]*=/, "")
      sub(/[[:space:]]+#.*$/, "")
      gsub(/^"|"$/, "")
      print
      exit
    }
  ' "$SHARED_ENV" 2>/dev/null || true)
  printf '%s' "${value:-$default}"
}

expand_runtime_value() {
  local value=$1
  value=${value//\$\{HOME\}/$HOME}
  value=${value//\$HOME/$HOME}
  value=${value/#\~/$HOME}
  printf '%s' "$value"
}

manifest_update() {
  local manifest=$1
  local status=$2
  local previous=${3:-}
  local rollback=${4:-}
  local error=${5:-}
  python3 - "$manifest" "$status" "$previous" "$rollback" "$error" <<'PY'
from __future__ import annotations

import json
import os
import sys
from datetime import datetime, timezone

path, status, previous, rollback, error = sys.argv[1:]
try:
    with open(path, encoding="utf-8") as handle:
        payload = json.load(handle)
except FileNotFoundError:
    payload = {}

payload["status"] = status
payload["updated_at"] = datetime.now(timezone.utc).isoformat()
if status in {"succeeded", "rolled_back", "failed", "rollback_failed"}:
    payload["finished_at"] = payload["updated_at"]
if previous:
    payload["previous_release_id"] = previous
if rollback:
    payload["rollback_release_id"] = rollback
if error:
    payload["error"] = error
else:
    payload.pop("error", None)
if status == "succeeded":
    payload["health_checks"] = {"api": "ok", "ui": "ok", "langfuse": "ok"}

temporary = f"{path}.tmp"
with open(temporary, "w", encoding="utf-8") as handle:
    json.dump(payload, handle, ensure_ascii=False, indent=2, sort_keys=True)
    handle.write("\n")
os.replace(temporary, path)
PY
}

ensure_shared_env() {
  mkdir -p "$SHARED_DIR" "$RELEASES_DIR"
  if [[ -f "$SHARED_ENV" ]]; then
    chmod 600 "$SHARED_ENV"
    return 0
  fi
  if [[ -f "$RELEASE_ROOT/docker/.env" ]]; then
    install -m 600 "$RELEASE_ROOT/docker/.env" "$SHARED_ENV"
    return 0
  fi
  die "private Compose env is missing: $SHARED_ENV"
}

bootstrap_legacy_release() {
  local image legacy_dir legacy_tmp legacy_version
  local -a legacy_images
  [[ ! -e "$CURRENT_LINK" ]] || return 0
  [[ -f "$RELEASE_ROOT/docker/docker-compose.yml" ]] || return 0

  legacy_dir="$RELEASES_DIR/legacy-bootstrap"
  if [[ ! -d "$legacy_dir" ]]; then
    log "Importing the existing Compose deployment as legacy-bootstrap"
    legacy_tmp="$RELEASES_DIR/.legacy-bootstrap.$$"
    rm -rf "$legacy_tmp"
    mkdir -p "$legacy_tmp/images"
    (
      cd "$RELEASE_ROOT"
      tar \
        --exclude='./.deploy.lock' \
        --exclude='./.git' \
        --exclude='./current' \
        --exclude='./images' \
        --exclude='./releases' \
        --exclude='./shared' \
        -cf - .
    ) | (cd "$legacy_tmp" && tar -xf -)
    legacy_version=$(tr -d '[:space:]' < "$legacy_tmp/VERSION")
    printf '%s\n' "$legacy_version" > "$legacy_tmp/.app-version"
    mapfile -t legacy_images < <(
      cd "$legacy_tmp"
      APP_VERSION="$legacy_version" docker compose \
        --env-file "$SHARED_ENV" -f docker/docker-compose.yml \
        --profile langfuse config --images | awk 'NF' | sort -u
    )
    (( ${#legacy_images[@]} > 0 )) || die "legacy deployment resolved no images"
    for image in "${legacy_images[@]}"; do
      docker image inspect "$image" >/dev/null \
        || die "legacy image is unavailable for rollback capture: $image"
    done
    docker save "${legacy_images[@]}" | gzip -1 \
      > "$legacy_tmp/images/legacy-images.tar.gz"
    (
      cd "$legacy_tmp/images"
      sha256sum legacy-images.tar.gz > legacy-images.tar.gz.sha256
    )
    python3 - "$legacy_tmp/release.json" "$legacy_version" <<'PY'
import json
import sys
from datetime import datetime, timezone

path, version = sys.argv[1:]
payload = {
    "release_id": "legacy-bootstrap",
    "image_version": version,
    "status": "succeeded",
    "source": "legacy-import",
    "updated_at": datetime.now(timezone.utc).isoformat(),
}
with open(path, "w", encoding="utf-8") as handle:
    json.dump(payload, handle, ensure_ascii=False, indent=2, sort_keys=True)
    handle.write("\n")
PY
    mv "$legacy_tmp" "$legacy_dir"
  fi
  atomic_current_link "$legacy_dir"
}

atomic_current_link() {
  local target=$1
  local temporary="$RELEASE_ROOT/.current.$$.tmp"
  ln -s "$target" "$temporary"
  mv -Tf "$temporary" "$CURRENT_LINK"
}

prepare_runtime_root() {
  local clickhouse_gid clickhouse_uid identity minio_gid minio_uid
  local postgres_gid postgres_uid redis_gid redis_uid runtime_root
  runtime_root=$(expand_runtime_value "$(read_env HOST_RUNTIME_VOLUME_ROOT '$HOME/volume-agent-gov')")
  postgres_uid=$(read_env LANGFUSE_POSTGRES_UID 999)
  postgres_gid=$(read_env LANGFUSE_POSTGRES_GID 999)
  clickhouse_uid=$(read_env LANGFUSE_CLICKHOUSE_UID 101)
  clickhouse_gid=$(read_env LANGFUSE_CLICKHOUSE_GID 101)
  redis_uid=$(read_env LANGFUSE_REDIS_UID 999)
  redis_gid=$(read_env LANGFUSE_REDIS_GID 999)
  minio_uid=$(read_env LANGFUSE_MINIO_UID 65532)
  minio_gid=$(read_env LANGFUSE_MINIO_GID 65532)
  for identity in \
    "$postgres_uid" "$postgres_gid" "$clickhouse_uid" "$clickhouse_gid" \
    "$redis_uid" "$redis_gid" "$minio_uid" "$minio_gid"; do
    [[ "$identity" =~ ^[0-9]+$ ]] || die "runtime UID/GID must be numeric: $identity"
  done
  log "Using runtime root=$runtime_root"
  install -d -m 750 \
    "$runtime_root/data" \
    "$runtime_root/governor-workspace" \
    "$runtime_root/claude-roots/governor" \
    "$runtime_root/langfuse" \
    "$runtime_root/langfuse/clickhouse"
  install -d -m 750 -o "$postgres_uid" -g "$postgres_gid" \
    "$runtime_root/langfuse/postgres"
  install -d -m 750 -o "$clickhouse_uid" -g "$clickhouse_gid" \
    "$runtime_root/langfuse/clickhouse/data" \
    "$runtime_root/langfuse/clickhouse/logs"
  install -d -m 750 -o "$redis_uid" -g "$redis_gid" \
    "$runtime_root/langfuse/redis"
  install -d -m 750 -o "$minio_uid" -g "$minio_gid" \
    "$runtime_root/langfuse/minio"
}

compose_down() {
  local directory=$1
  local image_version
  [[ -f "$directory/docker/docker-compose.yml" ]] || return 0
  image_version=$(tr -d '[:space:]' < "$directory/.app-version")
  (
    cd "$directory"
    APP_VERSION="$image_version" docker compose \
      --env-file "$SHARED_ENV" \
      -f docker/docker-compose.yml \
      --profile langfuse down --remove-orphans
  ) || true
}

cleanup_leftovers() {
  local prefix leftovers
  prefix=$(read_env CONTAINER_NAME_PREFIX agent-gov)
  leftovers=$(docker ps -aq --filter "name=${prefix}-" || true)
  if [[ -n "$leftovers" ]]; then
    docker rm -f $leftovers
  fi
}

compose_up() {
  local directory=$1
  local image_version
  image_version=$(tr -d '[:space:]' < "$directory/.app-version")
  prepare_runtime_root
  cleanup_leftovers
  # 调用方以 `set +e` + `compose_up && health_check` 调本函数，errexit 在此失效；
  # 若让子 shell 隐式返回最后一条语句（ps）的状态，up 的失败会被静默吞掉。
  # 因此必须显式捕获 up 的结果，ps 仅用于留痕。
  local up_rc=0
  (
    cd "$directory"
    APP_VERSION="$image_version" docker compose \
      --env-file "$SHARED_ENV" \
      -f docker/docker-compose.yml \
      --profile langfuse up -d --wait --wait-timeout 180 \
      --remove-orphans --force-recreate --no-build --pull never
  ) || up_rc=$?
  (
    cd "$directory"
    APP_VERSION="$image_version" docker compose \
      --env-file "$SHARED_ENV" \
      -f docker/docker-compose.yml \
      --profile langfuse ps
  ) || true
  return "$up_rc"
}

health_check() {
  local directory=$1
  local host_port frontend_port langfuse_port
  host_port=$(expand_runtime_value "$(read_env HOST_PORT 58080)")
  frontend_port=$(expand_runtime_value "$(read_env FRONTEND_HOST_PORT 55173)")
  langfuse_port=$(expand_runtime_value "$(read_env LANGFUSE_HOST_PORT 53000)")
  local smoke_rc=0
  python3 - "$host_port" "$frontend_port" "$langfuse_port" <<'PY' || smoke_rc=$?
from __future__ import annotations

import json
import sys
import time
from urllib.error import HTTPError
from urllib.request import Request, urlopen

host_port, frontend_port, langfuse_port = sys.argv[1:]
checks = [
    ("API readiness", f"http://127.0.0.1:{host_port}/health/ready", 60, True),
    ("UI", f"http://127.0.0.1:{frontend_port}", 60, False),
    ("Langfuse", f"http://127.0.0.1:{langfuse_port}", 90, False),
]
for name, url, attempts, require_ok_payload in checks:
    last_error: object | None = None
    for _ in range(attempts):
        try:
            request = Request(url, headers={"User-Agent": "agent-gov-release-smoke"})
            with urlopen(request, timeout=5) as response:
                body = response.read(500)
                if not 200 <= response.status < 300:
                    raise RuntimeError(f"unexpected HTTP status {response.status}")
                if require_ok_payload and json.loads(body.decode("utf-8")).get("status") != "ok":
                    raise RuntimeError("AgentGov health payload is not ok")
                print(f"{name} OK: {url} status={response.status}")
                break
        except HTTPError as exc:
            last_error = f"HTTP {exc.code}"
            time.sleep(2)
        except Exception as exc:  # noqa: BLE001 - remote smoke reports the final diagnostic.
            last_error = exc
            time.sleep(2)
    else:
        raise SystemExit(f"{name} failed: {url}: {last_error!r}")
PY
  # 诊断只用于失败留痕，其成败不得决定体检结论：函数返回值必须来自上面的冒烟检查。
  python3 "$directory/scripts/diagnose_runtime_health.py" \
    --api-base "http://127.0.0.1:${host_port}" --wait-seconds 5 || true
  return "$smoke_rc"
}

load_release_images() {
  local directory=$1
  local archive
  local -a archives
  shopt -s nullglob
  archives=("$directory/images/"*.tar.gz)
  shopt -u nullglob
  (( ${#archives[@]} > 0 )) || die "release has no image archives: $directory"
  for archive in "${archives[@]}"; do
    [[ -f "$archive.sha256" ]] || die "missing checksum: $archive.sha256"
    (cd "$(dirname "$archive")" && sha256sum -c "$(basename "$archive").sha256")
    gzip -dc "$archive" | docker load
  done
}

diagnose_release() {
  local directory=$1
  local image_version
  image_version=$(tr -d '[:space:]' < "$directory/.app-version")
  (
    cd "$directory"
    APP_VERSION="$image_version" docker compose \
      --env-file "$SHARED_ENV" -f docker/docker-compose.yml --profile langfuse ps || true
    bash scripts/compose_diagnose.sh || true
  )
}

deploy_release() {
  local directory previous_path previous_id rc
  validate_release_id "$RELEASE_ID"
  directory=$(release_dir "$RELEASE_ID")
  [[ -d "$directory" ]] || die "release does not exist: $RELEASE_ID"
  ensure_shared_env "$directory"
  bootstrap_legacy_release
  # readlink -e 要求路径每一段都存在：全新目标机上 current 尚未建立时必须得到空串，
  # 否则 -f 会返回一个不存在的路径且 rc=0，把"首次部署"误判为"有上一版可回滚"。
  previous_path=$(readlink -e "$CURRENT_LINK" 2>/dev/null || true)
  previous_id=$(release_id_from_path "$previous_path")

  if [[ "$previous_path" == "$directory" ]]; then
    log "Release $RELEASE_ID is already current; reconciling Compose state"
    load_release_images "$directory"
    compose_up "$directory"
    health_check "$directory"
    manifest_update "$directory/release.json" succeeded "$previous_id"
    return 0
  fi

  manifest_update "$directory/release.json" deploying "$previous_id"
  load_release_images "$directory"
  [[ -z "$previous_path" ]] || compose_down "$previous_path"

  set +e
  compose_up "$directory" && health_check "$directory"
  rc=$?
  set -e
  if (( rc == 0 )); then
    atomic_current_link "$directory"
    manifest_update "$directory/release.json" succeeded "$previous_id"
    log "Release $RELEASE_ID is healthy and current"
    return 0
  fi

  log "Release $RELEASE_ID failed health validation; restoring $previous_id"
  diagnose_release "$directory"
  compose_down "$directory"
  if [[ -n "$previous_path" ]]; then
    load_release_images "$previous_path"
    set +e
    compose_up "$previous_path" && health_check "$previous_path"
    rc=$?
    set -e
    if (( rc == 0 )); then
      atomic_current_link "$previous_path"
      manifest_update "$directory/release.json" rolled_back "$previous_id" "$previous_id" "deployment health check failed"
      log "Automatic rollback to $previous_id succeeded"
      return 2
    fi
  fi

  manifest_update "$directory/release.json" rollback_failed "$previous_id" "$previous_id" "deployment and rollback failed"
  log "Automatic rollback failed"
  return 3
}

rollback_release() {
  local target current_path current_id rc
  validate_release_id "$RELEASE_ID"
  target=$(release_dir "$RELEASE_ID")
  [[ -d "$target" ]] || die "rollback target does not exist: $RELEASE_ID"
  ensure_shared_env "$target"
  current_path=$(readlink -e "$CURRENT_LINK" 2>/dev/null || true)
  current_id=$(release_id_from_path "$current_path")
  if [[ "$current_path" == "$target" ]]; then
    load_release_images "$target"
    compose_up "$target"
    health_check "$target"
    log "Release $RELEASE_ID is already current"
    return 0
  fi

  [[ -z "$current_path" ]] || compose_down "$current_path"
  load_release_images "$target"
  set +e
  compose_up "$target" && health_check "$target"
  rc=$?
  set -e
  if (( rc == 0 )); then
    atomic_current_link "$target"
    manifest_update "$target/release.json" succeeded "$current_id"
    [[ -z "$current_path" ]] || manifest_update "$current_path/release.json" rolled_back "$current_id" "$RELEASE_ID"
    log "Rollback activated $RELEASE_ID"
    return 0
  fi

  diagnose_release "$target"
  compose_down "$target"
  if [[ -n "$current_path" ]]; then
    load_release_images "$current_path"
    set +e
    compose_up "$current_path" && health_check "$current_path"
    rc=$?
    set -e
    if (( rc == 0 )); then
      atomic_current_link "$current_path"
    fi
  fi
  manifest_update "$target/release.json" rollback_failed "$current_id" "$current_id" "manual rollback target failed health validation"
  return 3
}

status_json() {
  python3 - "$RELEASE_ROOT" <<'PY'
from __future__ import annotations

import json
import os
import sys
from pathlib import Path

root = Path(sys.argv[1])
current = root / "current"
active = Path(os.path.realpath(current)).name if current.exists() else None
releases = []
for manifest in sorted((root / "releases").glob("*/release.json"), reverse=True):
    try:
        releases.append(json.loads(manifest.read_text(encoding="utf-8")))
    except (OSError, json.JSONDecodeError):
        releases.append({"release_id": manifest.parent.name, "status": "invalid_manifest"})
print(json.dumps({"active_release": active, "releases": releases}, ensure_ascii=False, indent=2, sort_keys=True))
PY
}

mkdir -p "$RELEASE_ROOT" "$RELEASES_DIR" "$SHARED_DIR"
case "$COMMAND" in
  deploy|rollback)
    [[ -n "$RELEASE_ID" ]] || die "--release-id is required for $COMMAND"
    command -v flock >/dev/null 2>&1 || die "required command not found: flock"
    exec 9>"$LOCK_FILE"
    flock -n 9 || die "another release operation holds $LOCK_FILE"
    if [[ "$COMMAND" == "deploy" ]]; then
      deploy_release
    else
      rollback_release
    fi
    ;;
  status)
    status_json
    ;;
  diagnose)
    [[ -n "$RELEASE_ID" ]] || die "--release-id is required for diagnose"
    target=$(release_dir "$RELEASE_ID")
    [[ -d "$target" ]] || die "release does not exist: $RELEASE_ID"
    ensure_shared_env "$target"
    diagnose_release "$target"
    ;;
  *)
    die "unknown command: $COMMAND"
    ;;
esac
