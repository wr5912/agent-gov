#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
DEFAULT_HOST="172.16.112.232"
DEFAULT_REMOTE_DIR="~/work/agent-gov"
DEFAULT_ENVIRONMENT="staging-232"
EXPECTED_GIT_REMOTE_PROJECT="agent-gov"
COMPOSE_FILE="docker/docker-compose.yml"
LOCAL_COMPOSE_ENV_FILE="${LOCAL_COMPOSE_ENV_FILE:-docker/.env}"
SOURCE_REPO_DIR="${AGENT_GOV_SOURCE_REPO_DIR:-$ROOT_DIR}"
SOURCE_REPOSITORY="${AGENT_GOV_REPOSITORY:-wr5912/agent-gov}"
REMOTE_HELPER="${AGENT_GOV_REMOTE_HELPER:-$ROOT_DIR/scripts/agent_gov_release_remote}"

usage() {
  cat <<'USAGE'
Usage:
  scripts/deploy_agent_gov_to_host \
    --ref <40-character-master-SHA> \
    [--host 172.16.112.232] \
    [--environment staging-232]

  scripts/deploy_agent_gov_to_host --preflight-only --ref <SHA> [options]
  scripts/deploy_agent_gov_to_host --rollback <release-id> [options]
  scripts/deploy_agent_gov_to_host --diagnose <release-id> [options]
  scripts/deploy_agent_gov_to_host --remote-status [options]

--remote-status 把目标机实际在跑的版本以 JSON 打到 stdout（日志走 stderr），
供控制器对账 active 指针使用。

Options:
  --host <host>              Default: 172.16.112.232
  --environment <name>      Default: staging-232
  --aid <AID-N>             Optional trace identifier; the controller supplies it.
  --pr-number <number>       Optional pull request number.
  --workflow-url <url>       Optional successful quality-gate URL.

Environment:
  DEPLOY_USER                SSH user, default root.
  REMOTE_DIR                 Release root, default ~/work/agent-gov.
  SSH_KNOWN_HOSTS_FILE       Pinned known_hosts file, default ~/.ssh/known_hosts.
  LOCAL_COMPOSE_ENV_FILE     Complete local build env selection, default docker/.env.
  AGENT_GOV_SOURCE_REPO_DIR  Read-only agent-gov source clone used for exact archives.
  AGENT_GOV_REPOSITORY       GitHub owner/repository written to release metadata.
  AGENT_GOV_REMOTE_HELPER    External remote helper; defaults inside this module.

The deploy path requires an exact full SHA reachable from origin/master. It
builds immutable SHA-tagged images, writes release.json, deploys through a
serialized remote helper, and immediately restores the previous healthy
release if health validation fails. GitHub credentials are never read here.
USAGE
}

MODE="deploy"
REF_SHA=""
DEPLOY_HOST="${DEPLOY_HOST:-$DEFAULT_HOST}"
ENVIRONMENT="${DEPLOY_ENVIRONMENT:-$DEFAULT_ENVIRONMENT}"
ROLLBACK_RELEASE_ID=""
DIAGNOSE_RELEASE_ID=""
AID_IDENTIFIER=""
PR_NUMBER=""
WORKFLOW_URL=""
POSITIONAL_HOST_SEEN=0

while (( $# )); do
  case "$1" in
    --ref)
      REF_SHA=${2:-}
      shift 2
      ;;
    --host)
      DEPLOY_HOST=${2:-}
      shift 2
      ;;
    --environment)
      ENVIRONMENT=${2:-}
      shift 2
      ;;
    --preflight-only)
      MODE="preflight"
      shift
      ;;
    --rollback)
      MODE="rollback"
      ROLLBACK_RELEASE_ID=${2:-}
      shift 2
      ;;
    --diagnose)
      MODE="diagnose"
      DIAGNOSE_RELEASE_ID=${2:-}
      shift 2
      ;;
    --remote-status)
      MODE="remote-status"
      shift
      ;;
    --aid)
      AID_IDENTIFIER=${2:-}
      shift 2
      ;;
    --pr-number)
      PR_NUMBER=${2:-}
      shift 2
      ;;
    --workflow-url)
      WORKFLOW_URL=${2:-}
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -* )
      printf '[deploy] ERROR: unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 1
      ;;
    *)
      if (( POSITIONAL_HOST_SEEN )); then
        printf '[deploy] ERROR: unexpected positional argument: %s\n' "$1" >&2
        exit 1
      fi
      DEPLOY_HOST=$1
      POSITIONAL_HOST_SEEN=1
      shift
      ;;
  esac
done

DEPLOY_USER="${DEPLOY_USER:-root}"
REMOTE_DIR="${REMOTE_DIR:-$DEFAULT_REMOTE_DIR}"
REMOTE="${DEPLOY_USER}@${DEPLOY_HOST}"
SSH_CONNECT_TIMEOUT="${SSH_CONNECT_TIMEOUT:-10}"
SSH_KNOWN_HOSTS_FILE="${SSH_KNOWN_HOSTS_FILE:-$HOME/.ssh/known_hosts}"
LOCAL_TARGET=0
TARGET_LABEL="$REMOTE"
SSH_OPTIONS=(
  -o StrictHostKeyChecking=yes
  -o BatchMode=yes
  -o "ConnectTimeout=${SSH_CONNECT_TIMEOUT}"
  -o "UserKnownHostsFile=${SSH_KNOWN_HOSTS_FILE}"
)

log() {
  printf '[deploy] %s\n' "$*"
}

die() {
  printf '[deploy] ERROR: %s\n' "$*" >&2
  exit 1
}

quote() {
  printf '%q' "$1"
}

is_local_host() {
  case "$1" in
    localhost|127.0.0.1|::1) return 0 ;;
    *) return 1 ;;
  esac
}

if is_local_host "$DEPLOY_HOST"; then
  LOCAL_TARGET=1
  TARGET_LABEL="localhost"
fi

target_run() {
  if (( LOCAL_TARGET )); then
    bash -c "$1"
  else
    ssh "${SSH_OPTIONS[@]}" "$REMOTE" "$@"
  fi
}

rsync_ssh_command() {
  local command="ssh"
  local option
  for option in "${SSH_OPTIONS[@]}"; do
    command+=" $(quote "$option")"
  done
  printf '%s' "$command"
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

validate_environment() {
  [[ "$ENVIRONMENT" =~ ^[A-Za-z0-9._-]+$ ]] || die "invalid environment: $ENVIRONMENT"
}

validate_release_id() {
  [[ "$1" =~ ^[A-Za-z0-9._-]+$ ]] || die "invalid release id: $1"
}

validate_trace_arguments() {
  if [[ -n "$AID_IDENTIFIER" && ! "$AID_IDENTIFIER" =~ ^AID-[0-9]+$ ]]; then
    die "invalid AID identifier: $AID_IDENTIFIER"
  fi
  if [[ -n "$PR_NUMBER" && ! "$PR_NUMBER" =~ ^[0-9]+$ ]]; then
    die "invalid pull request number: $PR_NUMBER"
  fi
}

validate_git_origin_project() {
  local remote_url remote_project
  remote_url=$(git -C "$SOURCE_REPO_DIR" remote get-url origin 2>/dev/null) \
    || die "git origin remote is required in $SOURCE_REPO_DIR"
  remote_url=${remote_url%/}
  remote_project=${remote_url##*/}
  remote_project=${remote_project##*:}
  remote_project=${remote_project%.git}
  [[ "$remote_project" == "$EXPECTED_GIT_REMOTE_PROJECT" ]] \
    || die "git origin project must be $EXPECTED_GIT_REMOTE_PROJECT, got ${remote_project:-<empty>}"
}

resolve_exact_master_sha() {
  [[ "$REF_SHA" =~ ^[0-9a-f]{40}$ ]] || die "--ref must be a lowercase full 40-character commit SHA"
  git -C "$SOURCE_REPO_DIR" fetch origin master --prune
  local resolved
  resolved=$(git -C "$SOURCE_REPO_DIR" rev-parse --verify "${REF_SHA}^{commit}" 2>/dev/null) \
    || die "commit is unavailable after fetching origin/master: $REF_SHA"
  [[ "$resolved" == "$REF_SHA" ]] || die "--ref did not resolve exactly to $REF_SHA"
  git -C "$SOURCE_REPO_DIR" merge-base --is-ancestor "$REF_SHA" origin/master \
    || die "commit is not reachable from origin/master: $REF_SHA"
}

resolve_remote_path() {
  REMOTE_PATH=$(target_run "REMOTE_DIR=$(quote "$REMOTE_DIR") python3 - <<'PY'
import os
print(os.path.abspath(os.path.expanduser(os.environ['REMOTE_DIR'])))
PY
")
  [[ -n "$REMOTE_PATH" ]] || die "failed to resolve target release root"
}

ensure_local_target_is_not_current_repo() {
  local source_real target_real
  (( LOCAL_TARGET )) || return 0
  source_real=$(python3 -c 'import os, sys; print(os.path.realpath(sys.argv[1]))' "$SOURCE_REPO_DIR")
  target_real=$(python3 -c 'import os, sys; print(os.path.realpath(sys.argv[1]))' "$REMOTE_PATH")
  [[ "$target_real" != "$source_real" ]] \
    || die "local target dir must not be the source repository: $REMOTE_PATH"
}

target_preflight() {
  log "Checking target prerequisites on $TARGET_LABEL"
  target_run "command -v awk >/dev/null \
    && command -v python3 >/dev/null \
    && command -v docker >/dev/null \
    && command -v flock >/dev/null \
    && command -v gzip >/dev/null \
    && command -v install >/dev/null \
    && command -v sha256sum >/dev/null \
    && command -v sort >/dev/null \
    && command -v tar >/dev/null \
    && docker compose version >/dev/null"
  resolve_remote_path
  ensure_local_target_is_not_current_repo
}

sync_remote_helper() {
  local helper_dir="$REMOTE_PATH/shared/bin"
  local helper_path="$helper_dir/agent-gov-release-remote"
  local temporary="$helper_dir/.agent-gov-release-remote.$$"
  [[ -f "$REMOTE_HELPER" ]] || die "remote helper not found: $REMOTE_HELPER"
  target_run "mkdir -p $(quote "$helper_dir")"
  if (( LOCAL_TARGET )); then
    install -m 755 "$REMOTE_HELPER" "$temporary"
  else
    rsync -a -e "$(rsync_ssh_command)" --chmod=F755 \
      "$REMOTE_HELPER" "${REMOTE}:${temporary}"
  fi
  target_run "chmod 755 $(quote "$temporary") && mv -f $(quote "$temporary") $(quote "$helper_path")"
}

install_shared_env_if_missing() {
  local shared_env="$REMOTE_PATH/shared/docker.env"
  target_run "mkdir -p $(quote "$REMOTE_PATH/releases") $(quote "$REMOTE_PATH/shared")"
  if target_run "test -f $(quote "$shared_env")"; then
    target_run "chmod 600 $(quote "$shared_env")"
    return 0
  fi
  if target_run "test -f $(quote "$REMOTE_PATH/docker/.env")"; then
    target_run "install -m 600 $(quote "$REMOTE_PATH/docker/.env") $(quote "$shared_env")"
    return 0
  fi
  die "target private Compose env is missing: $shared_env"
}

ensure_local_image() {
  local image=$1
  if ! docker image inspect "$image" >/dev/null 2>&1; then
    log "Local image missing, pulling: $image"
    docker pull "$image"
  fi
}

dedupe_images() {
  local image
  declare -A seen=()
  for image in "$@"; do
    [[ -n "$image" ]] || continue
    if [[ -z "${seen[$image]+x}" ]]; then
      seen[$image]=1
      printf '%s\n' "$image"
    fi
  done
}

resolve_dependency_images() {
  mapfile -t DEPENDENCY_IMAGES < <(target_run "bash -s -- $(quote "$REMOTE_PATH/shared/docker.env")" <<'REMOTE_IMAGES'
set -euo pipefail
env_file=$1
env_value() {
  local key=$1
  local default=$2
  local value
  value=$(awk -F= -v key="$key" '
    $1 == key {
      sub(/^[^=]*=/, "")
      sub(/[[:space:]]+#.*$/, "")
      gsub(/^"|"$/, "")
      print
      exit
    }
  ' "$env_file" 2>/dev/null || true)
  printf '%s\n' "${value:-$default}"
}
env_value LANGFUSE_WORKER_IMAGE docker.io/langfuse/langfuse-worker:3
env_value LANGFUSE_WEB_IMAGE docker.io/langfuse/langfuse:3
env_value LANGFUSE_POSTGRES_IMAGE docker.io/postgres:17
env_value LANGFUSE_CLICKHOUSE_IMAGE docker.io/clickhouse/clickhouse-server:24.3
env_value LANGFUSE_REDIS_IMAGE docker.io/redis:7
env_value LANGFUSE_MINIO_IMAGE cgr.dev/chainguard/minio
REMOTE_IMAGES
  )
  mapfile -t DEPENDENCY_IMAGES < <(dedupe_images "${DEPENDENCY_IMAGES[@]}")
}

sync_release_code() {
  local release_path="$REMOTE_PATH/releases/$RELEASE_ID"
  log "Syncing exact commit $REF_SHA into $release_path"
  if (( LOCAL_TARGET )); then
    mkdir -p "$release_path"
    rsync -az --delete "$TMP_DIR/" "$release_path/"
  else
    rsync -az --delete -e "$(rsync_ssh_command)" \
      "$TMP_DIR/" "${REMOTE}:${release_path}/"
  fi
  target_run "mkdir -p $(quote "$release_path/images")"
}

upload_image_archive() {
  local target_name=$1
  shift
  local images=("$@")
  local release_images="$REMOTE_PATH/releases/$RELEASE_ID/images"
  log "Writing $target_name for release $RELEASE_ID"
  docker save "${images[@]}" | gzip -1 | target_run "bash -c 'set -euo pipefail
    target_dir=\$1
    target_name=\$2
    temporary=\"\$target_dir/\${target_name}.tmp\"
    mkdir -p \"\$target_dir\"
    cat > \"\$temporary\"
    mv \"\$temporary\" \"\$target_dir/\$target_name\"
    cd \"\$target_dir\"
    sha256sum \"\$target_name\" > \"\$target_name.sha256\"
  ' bash $(quote "$release_images") $(quote "$target_name")"
}

write_release_metadata() {
  local manifest="$TMP_DIR/release.json"
  local app_version_file="$TMP_DIR/.app-version"
  local image digest
  local image_args=()
  printf '%s\n' "$IMAGE_VERSION" > "$app_version_file"
  for image in "${PROJECT_IMAGES[@]}" "${DEPENDENCY_IMAGES[@]}"; do
    digest=$(docker image inspect --format '{{.Id}}' "$image")
    image_args+=("${image}=${digest}")
  done
  python3 - "$manifest" "$RELEASE_ID" "$AID_IDENTIFIER" "$SOURCE_REPOSITORY" \
    "$REF_SHA" "$IMAGE_VERSION" "$ENVIRONMENT" "$DEPLOY_HOST" "$PR_NUMBER" \
    "$WORKFLOW_URL" "${image_args[@]}" <<'PY'
from __future__ import annotations

import json
import sys
from datetime import datetime, timezone

(
    path,
    release_id,
    aid,
    repository,
    sha,
    image_version,
    environment,
    host,
    pr_number,
    workflow_url,
    *image_pairs,
) = sys.argv[1:]
images = {}
for pair in image_pairs:
    name, digest = pair.rsplit("=", 1)
    images[name] = digest
payload = {
    "release_id": release_id,
    "aid_identifier": aid or None,
    "repository": repository,
    "commit_sha": sha,
    "image_version": image_version,
    "image_digests": images,
    "environment": environment,
    "host": host,
    "pr_number": int(pr_number) if pr_number else None,
    "workflow_url": workflow_url or None,
    "status": "prepared",
    "created_at": datetime.now(timezone.utc).isoformat(),
}
with open(path, "w", encoding="utf-8") as handle:
    json.dump(payload, handle, ensure_ascii=False, indent=2, sort_keys=True)
    handle.write("\n")
PY
  local release_path="$REMOTE_PATH/releases/$RELEASE_ID"
  if (( LOCAL_TARGET )); then
    install -m 644 "$manifest" "$release_path/release.json"
    install -m 644 "$app_version_file" "$release_path/.app-version"
  else
    rsync -a -e "$(rsync_ssh_command)" "$manifest" "${REMOTE}:${release_path}/release.json"
    rsync -a -e "$(rsync_ssh_command)" "$app_version_file" "${REMOTE}:${release_path}/.app-version"
  fi
}

invoke_remote_helper() {
  local command=$1
  # status 不针对某个 release，故 release-id 可选：不传就不下发该参数，
  # 而不是下发一个空串让远端脚本去猜。
  local release_id=${2:-}
  local helper="$REMOTE_PATH/shared/bin/agent-gov-release-remote"
  local remote_command
  remote_command="$(quote "$helper") $(quote "$command") --release-root $(quote "$REMOTE_PATH")"
  if [[ -n "$release_id" ]]; then
    remote_command+=" --release-id $(quote "$release_id")"
  fi
  target_run "$remote_command"
}

prepared_release_state() {
  local release_path="$REMOTE_PATH/releases/$RELEASE_ID"
  target_run "python3 - $(quote "$release_path") $(quote "$REF_SHA") \
    $(quote "$SOURCE_REPOSITORY") $(quote "$ENVIRONMENT")" <<'PY'
from __future__ import annotations

import hashlib
import json
import sys
from pathlib import Path

release = Path(sys.argv[1])
expected_sha, expected_repository, expected_environment = sys.argv[2:]
manifest_path = release / "release.json"
if not manifest_path.is_file():
    print("absent")
    raise SystemExit(0)
try:
    manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
except (OSError, json.JSONDecodeError) as exc:
    raise SystemExit(f"committed release manifest is invalid: {exc}") from exc
expected = {
    "commit_sha": expected_sha,
    "repository": expected_repository,
    "environment": expected_environment,
}
for key, value in expected.items():
    if manifest.get(key) != value:
        raise SystemExit(
            f"committed release {release.name} has conflicting {key}: "
            f"{manifest.get(key)!r} != {value!r}"
        )
version_path = release / ".app-version"
if not version_path.is_file() or version_path.read_text(encoding="utf-8").strip() != manifest.get(
    "image_version"
):
    raise SystemExit(f"committed release {release.name} has inconsistent image version")
for name in ("project-images.tar.gz", "dependency-images.tar.gz"):
    archive = release / "images" / name
    checksum = archive.with_name(f"{name}.sha256")
    if not archive.is_file() or not checksum.is_file():
        raise SystemExit(f"committed release {release.name} is missing {name} or its checksum")
    expected_digest = checksum.read_text(encoding="utf-8").split()[0]
    hasher = hashlib.sha256()
    with archive.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            hasher.update(chunk)
    digest = hasher.hexdigest()
    if digest != expected_digest:
        raise SystemExit(f"committed release {release.name} failed checksum validation for {name}")
print("ready")
PY
}

validate_environment
validate_trace_arguments

if [[ "$MODE" == "rollback" ]]; then
  [[ -n "$ROLLBACK_RELEASE_ID" ]] || die "--rollback requires a release id"
  validate_release_id "$ROLLBACK_RELEASE_ID"
  for command_name in install python3 rsync; do require_command "$command_name"; done
  (( LOCAL_TARGET )) || require_command ssh
  target_preflight
  sync_remote_helper
  set +e
  invoke_remote_helper rollback "$ROLLBACK_RELEASE_ID"
  rc=$?
  set -e
  exit "$rc"
fi

if [[ "$MODE" == "remote-status" ]]; then
  require_command python3
  (( LOCAL_TARGET )) || require_command ssh
  # 只读探测，刻意不做部署预检、也不同步 helper：
  # - 观测不该改写被观测对象。控制器每 30 秒对账一次，若在这里 rsync，就是每天往目标机
  #   写 2880 次文件，只为读一个符号链接；而且 rsync 一旦失败，会把"机器好好的"误报成
  #   探测失败。
  # - 部署预检查的是 docker/flock/gzip/tar，与读 current 无关；只有 resolve_remote_path
  #   是必需的（它定出 REMOTE_PATH）。
  # - helper 由部署安装。机器从没被部署过 → 没有 current 可对账 → 探测失败正是正确答案
  #   （控制器会记 active_probe_failed 并继续）。
  # 此路径不调用 log，故 stdout 天然只有 helper 输出的 JSON。
  resolve_remote_path
  invoke_remote_helper status
  exit 0
fi

if [[ "$MODE" == "diagnose" ]]; then
  [[ -n "$DIAGNOSE_RELEASE_ID" ]] || die "--diagnose requires a release id"
  validate_release_id "$DIAGNOSE_RELEASE_ID"
  for command_name in install python3 rsync; do require_command "$command_name"; done
  (( LOCAL_TARGET )) || require_command ssh
  target_preflight
  sync_remote_helper
  invoke_remote_helper diagnose "$DIAGNOSE_RELEASE_ID"
  exit 0
fi

[[ -n "$REF_SHA" ]] || die "--ref is required"
for command_name in git python3; do require_command "$command_name"; done
if (( LOCAL_TARGET )); then
  require_command rsync
else
  require_command ssh
fi
validate_git_origin_project
resolve_exact_master_sha
target_preflight

SHORT_SHA=${REF_SHA:0:12}
RELEASE_ID="${ENVIRONMENT}-${SHORT_SHA}"
validate_release_id "$RELEASE_ID"

if [[ "$MODE" == "preflight" ]]; then
  printf 'REF_SHA=%s\nRELEASE_ID=%s\nTARGET=%s:%s\n' \
    "$REF_SHA" "$RELEASE_ID" "$TARGET_LABEL" "$REMOTE_PATH"
  exit 0
fi

for command_name in docker gzip install rsync tar; do require_command "$command_name"; done

PREPARED_STATE=$(prepared_release_state)
if [[ "$PREPARED_STATE" == "ready" ]]; then
  log "Reusing committed immutable release $RELEASE_ID after idempotent reconciliation"
  sync_remote_helper
  printf 'RELEASE_ID=%s\n' "$RELEASE_ID"
  set +e
  invoke_remote_helper deploy "$RELEASE_ID"
  rc=$?
  set -e
  case "$rc" in
    0) log "Deployment completed: $RELEASE_ID" ;;
    2) log "Deployment failed and automatic rollback completed: $RELEASE_ID" ;;
    3) log "Deployment and rollback both failed: $RELEASE_ID" ;;
    *) log "Deployment preflight or transport failed: $RELEASE_ID" ;;
  esac
  exit "$rc"
fi
[[ "$PREPARED_STATE" == "absent" ]] || die "unexpected prepared release state: $PREPARED_STATE"

TMP_DIR=$(mktemp -d /tmp/agent-gov-release.XXXXXX)
trap 'rm -rf "$TMP_DIR"' EXIT
git -C "$SOURCE_REPO_DIR" archive "$REF_SHA" | tar -x -C "$TMP_DIR"
[[ -f "$TMP_DIR/$COMPOSE_FILE" ]] || die "$COMPOSE_FILE not found at $REF_SHA"
VERSION=$(tr -d '[:space:]' < "$TMP_DIR/VERSION")
[[ -n "$VERSION" ]] || die "VERSION is empty at $REF_SHA"
IMAGE_VERSION="${VERSION}-${SHORT_SHA}"

if [[ "$LOCAL_COMPOSE_ENV_FILE" = /* ]]; then
  LOCAL_COMPOSE_ENV_PATH="$LOCAL_COMPOSE_ENV_FILE"
else
  LOCAL_COMPOSE_ENV_PATH="$SOURCE_REPO_DIR/$LOCAL_COMPOSE_ENV_FILE"
fi
if [[ ! -f "$LOCAL_COMPOSE_ENV_PATH" ]]; then
  LOCAL_COMPOSE_ENV_PATH="$TMP_DIR/docker/.env.example"
  log "$LOCAL_COMPOSE_ENV_FILE is absent; selecting the exact commit docker/.env.example for build interpolation"
fi

log "Consumer x Mode x Boundary: target containers select shared/docker.env; runtime data remains on the target; GitHub credentials remain in the controller"
log "Building immutable project images for $IMAGE_VERSION"
APP_VERSION="$IMAGE_VERSION" docker compose \
  --env-file "$LOCAL_COMPOSE_ENV_PATH" -f "$TMP_DIR/$COMPOSE_FILE" build \
  agent-gov-litellm-sidecar claude-agent-api claude-agent-ui

PROJECT_IMAGES=(
  "agent-gov-api:${IMAGE_VERSION}"
  "agent-gov-ui:${IMAGE_VERSION}"
  "agent-gov-litellm-sidecar:${IMAGE_VERSION}"
)
for image in "${PROJECT_IMAGES[@]}"; do ensure_local_image "$image"; done

install_shared_env_if_missing
sync_remote_helper
resolve_dependency_images
for image in "${DEPENDENCY_IMAGES[@]}"; do ensure_local_image "$image"; done

sync_release_code
upload_image_archive project-images.tar.gz "${PROJECT_IMAGES[@]}"
upload_image_archive dependency-images.tar.gz "${DEPENDENCY_IMAGES[@]}"
write_release_metadata

printf 'RELEASE_ID=%s\n' "$RELEASE_ID"
set +e
invoke_remote_helper deploy "$RELEASE_ID"
rc=$?
set -e
case "$rc" in
  0) log "Deployment completed: $RELEASE_ID" ;;
  2) log "Deployment failed and automatic rollback completed: $RELEASE_ID" ;;
  3) log "Deployment and rollback both failed: $RELEASE_ID" ;;
  *) log "Deployment preflight or transport failed: $RELEASE_ID" ;;
esac
exit "$rc"
