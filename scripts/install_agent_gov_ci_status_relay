#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
cd "$ROOT_DIR"

SERVICE_USER="agent-gov-ci-relay"
STATE_ROOT="/var/lib/agent-gov-ci-status-relay"
CONFIG_ROOT="/etc/agent-gov-ci-status-relay"
INSTALL_ROOT="/opt/agent-gov-ci-status-relay"
VERSIONS_ROOT="/opt/agent-gov-ci-status-relay/versions"
CURRENT_LINK="/opt/agent-gov-ci-status-relay/current"
LEGACY_SERVICE_USER="agent-gov-release"
LEGACY_STATE_ROOT="/var/lib/agent-gov-release-controller"
LEGACY_CONFIG_ROOT="/etc/agent-gov-release-controller"
LEGACY_AUDIT_ROOT="/var/lib/agent-gov-release-controller-audit"
LEGACY_AUDIT_FILE="$LEGACY_AUDIT_ROOT/release-controller-audit.json"
MULTICA_CONFIG=""

usage() {
  cat <<'USAGE'
Usage: sudo scripts/install_agent_gov_ci_status_relay \
  --multica-config <profile-config.json>

Prerequisite:
  Install a read-only GitHub PAT at
  /etc/agent-gov-ci-status-relay/github_token with mode 0600. The installer
  intentionally has no credential option, so secrets cannot enter argv.

The installer archives the exact HEAD from this clean, reviewed checkout into a
root-owned version directory and atomically updates a read-only current symlink.
The relay only reads GitHub Actions/PR metadata and writes terminal CI comments
to Multica. It receives no Docker group, SSH key, or deployment configuration.

If the retired automatic release controller exists, the installer stops it
before migration but keeps its credentials and files until the new relay
completes its first poll. Only then does it preserve an allowlisted audit
snapshot and remove the old Docker-group user, token, SSH files, profile, clone,
units, and releasectl.
USAGE
}

die() {
  printf 'ERROR: %s\n' "$*" >&2
  exit 1
}

while (( $# )); do
  case "$1" in
    --multica-config)
      MULTICA_CONFIG=${2:-}
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
done

[[ ${EUID:-$(id -u)} -eq 0 ]] || die "run this installer with sudo"
[[ -f "$MULTICA_CONFIG" ]] || die "--multica-config must name an existing file"
for command_name in chmod chown date getent git gpasswd grep id install ln multica mv python3 readlink rm systemctl tar useradd userdel; do
  command -v "$command_name" >/dev/null 2>&1 \
    || die "required command not found: $command_name"
done
git -c "safe.directory=$ROOT_DIR" -C "$ROOT_DIR" diff --quiet \
  || die "tracked checkout changes must be committed before relay installation"
git -c "safe.directory=$ROOT_DIR" -C "$ROOT_DIR" diff --cached --quiet \
  || die "staged checkout changes must be committed before relay installation"
SOURCE_SHA=$(git -c "safe.directory=$ROOT_DIR" -C "$ROOT_DIR" rev-parse --verify HEAD)
[[ "$SOURCE_SHA" =~ ^[0-9a-f]{40}$ ]] || die "checkout HEAD is not a full commit SHA"
staging_dir=""

cleanup_staging() {
  if [[ -n "$staging_dir" && -e "$staging_dir" ]]; then
    rm -rf "$staging_dir"
  fi
}

trap cleanup_staging EXIT

install -d -m 700 "$CONFIG_ROOT"
[[ -s "$CONFIG_ROOT/github_token" ]] \
  || die "install the read-only PAT at $CONFIG_ROOT/github_token before enabling the relay"
[[ ! -L "$CONFIG_ROOT/github_token" ]] || die "github_token must not be a symbolic link"
chown root:root "$CONFIG_ROOT/github_token"
chmod 600 "$CONFIG_ROOT/github_token"

if ! id "$SERVICE_USER" >/dev/null 2>&1; then
  useradd --system --home-dir "$STATE_ROOT" --create-home \
    --shell /usr/sbin/nologin "$SERVICE_USER"
fi
install -d -m 700 -o "$SERVICE_USER" -g "$SERVICE_USER" \
  "$STATE_ROOT" "$STATE_ROOT/state" "$STATE_ROOT/.cache"
install -d -m 700 -o "$SERVICE_USER" -g "$SERVICE_USER" \
  "$STATE_ROOT/.multica/profiles/ci-status-relay"
install -d -m 755 "$INSTALL_ROOT" "$VERSIONS_ROOT"

VERSION_DIR="$VERSIONS_ROOT/$SOURCE_SHA"
if [[ ! -d "$VERSION_DIR" ]]; then
  staging_dir="$INSTALL_ROOT/.staging-$SOURCE_SHA-$$"
  rm -rf "$staging_dir"
  install -d -m 755 "$staging_dir"
  git -c "safe.directory=$ROOT_DIR" -C "$ROOT_DIR" archive "$SOURCE_SHA" \
    | tar -x -C "$staging_dir"
  chown -R root:root "$staging_dir"
  chmod -R go-w "$staging_dir"
  mv "$staging_dir" "$VERSION_DIR"
  staging_dir=""
fi
[[ -f "$VERSION_DIR/scripts/agent_gov_ci_status_relay.py" ]] \
  || die "reviewed commit does not contain the relay"
[[ -f "$VERSION_DIR/scripts/snapshot_legacy_release_controller_audit.py" ]] \
  || die "reviewed commit does not contain the legacy audit snapshotter"

multica_binary=$(command -v multica)
if [[ "$multica_binary" != "/usr/local/bin/multica" ]]; then
  install -m 755 "$multica_binary" /usr/local/bin/multica
fi

PROFILE_CONFIG="$STATE_ROOT/.multica/profiles/ci-status-relay/config.json"
CONFIG_BACKUP="$CONFIG_ROOT/multica-config.pre-upgrade.$$"
HAD_CONFIG=0
PREVIOUS_TARGET=$(readlink -f "$CURRENT_LINK" 2>/dev/null || true)
if [[ -z "$PREVIOUS_TARGET" && -d "$STATE_ROOT/repository" ]]; then
  PREVIOUS_TARGET="$STATE_ROOT/repository"
fi

rollback_upgrade() {
  rc=$?
  trap - ERR
  printf 'ERROR: relay upgrade failed; restoring previous installation\n' >&2
  if [[ -n "$PREVIOUS_TARGET" ]]; then
    rollback_link="${CURRENT_LINK}.rollback.$$"
    rm -f "$rollback_link"
    ln -s "$PREVIOUS_TARGET" "$rollback_link"
    mv -Tf "$rollback_link" "$CURRENT_LINK"
  else
    rm -f "$CURRENT_LINK"
  fi
  if (( HAD_CONFIG )) && [[ -f "$CONFIG_BACKUP" ]]; then
    install -m 600 -o "$SERVICE_USER" -g "$SERVICE_USER" \
      "$CONFIG_BACKUP" "$PROFILE_CONFIG"
  else
    rm -f "$PROFILE_CONFIG"
  fi
  rm -f "$CONFIG_BACKUP"
  systemctl daemon-reload || true
  if [[ -n "$PREVIOUS_TARGET" ]]; then
    systemctl start agent-gov-ci-status-relay.service || true
    systemctl enable --now agent-gov-ci-status-relay.timer || true
  fi
  exit "$rc"
}

legacy_controller_present() {
  id "$LEGACY_SERVICE_USER" >/dev/null 2>&1 \
    || [[ -e "$LEGACY_STATE_ROOT" ]] \
    || [[ -L "$LEGACY_STATE_ROOT" ]] \
    || [[ -e "$LEGACY_CONFIG_ROOT" ]] \
    || [[ -L "$LEGACY_CONFIG_ROOT" ]] \
    || [[ -e /etc/systemd/system/agent-gov-release-controller.service ]] \
    || [[ -L /etc/systemd/system/agent-gov-release-controller.service ]] \
    || [[ -e /etc/systemd/system/agent-gov-release-controller.timer ]] \
    || [[ -L /etc/systemd/system/agent-gov-release-controller.timer ]] \
    || [[ -e /usr/local/bin/releasectl ]]
}

validate_legacy_audit_state() {
  python3 "$VERSION_DIR/scripts/snapshot_legacy_release_controller_audit.py" \
    --validate "$LEGACY_AUDIT_FILE" \
    || die "existing legacy audit snapshot failed allowlist validation"
}

preserve_legacy_audit_state() {
  local audit_tmp="$LEGACY_AUDIT_ROOT/.release-controller-audit.json.$$"
  if [[ -e "$LEGACY_AUDIT_FILE" || -L "$LEGACY_AUDIT_FILE" ]]; then
    [[ -f "$LEGACY_AUDIT_FILE" && ! -L "$LEGACY_AUDIT_FILE" && -s "$LEGACY_AUDIT_FILE" ]] \
      || die "existing legacy audit snapshot is not a non-empty regular file"
    validate_legacy_audit_state
    return 0
  fi
  install -d -m 700 -o root -g root "$LEGACY_AUDIT_ROOT"
  rm -f "$audit_tmp"
  python3 "$VERSION_DIR/scripts/snapshot_legacy_release_controller_audit.py" \
    --source "$LEGACY_STATE_ROOT/state/state.db" \
    --output "$audit_tmp"
  chown root:root "$audit_tmp"
  chmod 600 "$audit_tmp"
  if ! ln "$audit_tmp" "$LEGACY_AUDIT_FILE"; then
    rm -f "$audit_tmp"
    [[ -f "$LEGACY_AUDIT_FILE" && ! -L "$LEGACY_AUDIT_FILE" && -s "$LEGACY_AUDIT_FILE" ]] \
      || die "failed to preserve the immutable legacy audit snapshot"
    validate_legacy_audit_state
    return 0
  fi
  rm -f "$audit_tmp"
}

retire_legacy_release_controller() {
  legacy_controller_present || return 0

  preserve_legacy_audit_state
  systemctl disable --now agent-gov-release-controller.timer 2>/dev/null || true
  systemctl stop agent-gov-release-controller.service 2>/dev/null || true

  if id "$LEGACY_SERVICE_USER" >/dev/null 2>&1 \
    && getent group docker >/dev/null 2>&1 \
    && id -nG "$LEGACY_SERVICE_USER" | grep -Eq '(^|[[:space:]])docker([[:space:]]|$)'; then
    gpasswd -d "$LEGACY_SERVICE_USER" docker >/dev/null
  fi
  if id "$LEGACY_SERVICE_USER" >/dev/null 2>&1 \
    && id -nG "$LEGACY_SERVICE_USER" | grep -Eq '(^|[[:space:]])docker([[:space:]]|$)'; then
    die "legacy release-controller user still belongs to the docker group"
  fi

  rm -f \
    /etc/systemd/system/agent-gov-release-controller.service \
    /etc/systemd/system/agent-gov-release-controller.timer \
    /usr/local/bin/releasectl
  rm -rf "$LEGACY_CONFIG_ROOT" "$LEGACY_STATE_ROOT"
  if id "$LEGACY_SERVICE_USER" >/dev/null 2>&1; then
    userdel "$LEGACY_SERVICE_USER"
  fi
  systemctl daemon-reload
  printf '%s\n' \
    "Retired legacy release controller; sanitized audit: $LEGACY_AUDIT_FILE" \
    "ACTION REQUIRED: revoke the retired release-controller PAT at its GitHub owner; its local copy has been deleted."
}

trap rollback_upgrade ERR
systemctl stop agent-gov-ci-status-relay.timer 2>/dev/null || true
systemctl stop agent-gov-ci-status-relay.service 2>/dev/null || true
# Prevent the old automatic deployer from racing the migration. Its units,
# credentials, Docker-group identity and files remain intact until the new
# read-only relay completes the first one-shot poll below.
systemctl disable --now agent-gov-release-controller.timer 2>/dev/null || true
systemctl stop agent-gov-release-controller.service 2>/dev/null || true

if [[ -f "$PROFILE_CONFIG" ]]; then
  HAD_CONFIG=1
  install -m 600 "$PROFILE_CONFIG" "$CONFIG_BACKUP"
fi
install -m 600 -o "$SERVICE_USER" -g "$SERVICE_USER" \
  "$MULTICA_CONFIG" "$PROFILE_CONFIG"

temporary_link="${CURRENT_LINK}.new.$$"
rm -f "$temporary_link"
ln -s "$VERSION_DIR" "$temporary_link"
mv -Tf "$temporary_link" "$CURRENT_LINK"
ln -sfn "$CURRENT_LINK/deploy/systemd/agent-gov-ci-status-relay.service" \
  /etc/systemd/system/agent-gov-ci-status-relay.service
ln -sfn "$CURRENT_LINK/deploy/systemd/agent-gov-ci-status-relay.timer" \
  /etc/systemd/system/agent-gov-ci-status-relay.timer

if [[ ! -f "$CONFIG_ROOT/relay.env" ]]; then
  install -m 600 \
    "$CURRENT_LINK/deploy/systemd/agent-gov-ci-status-relay.env.example" \
    "$CONFIG_ROOT/relay.env"
fi
chown root:root "$CONFIG_ROOT/relay.env"
chmod 600 "$CONFIG_ROOT/relay.env"
if ! grep -Eq '^AGENT_GOV_RELAY_NOT_BEFORE=.+$' "$CONFIG_ROOT/relay.env"; then
  printf 'AGENT_GOV_RELAY_NOT_BEFORE=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    >> "$CONFIG_ROOT/relay.env"
fi

systemctl daemon-reload
systemctl start agent-gov-ci-status-relay.service
systemctl enable --now agent-gov-ci-status-relay.timer
systemctl --no-pager status agent-gov-ci-status-relay.timer
trap - ERR
rm -f "$CONFIG_BACKUP"
retire_legacy_release_controller
if [[ "$PREVIOUS_TARGET" == "$STATE_ROOT/repository" ]]; then
  rm -rf "$STATE_ROOT/repository"
fi
