#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
DEFAULT_HOST="172.16.112.232"
DEFAULT_REMOTE_DIR="~/work/agent-gov"
EXPECTED_GIT_REMOTE_PROJECT="agent-gov"

usage() {
  cat <<'USAGE'
Usage: scripts/restart_agent_gov_on_host [host]

Restart the full AgentGov Docker Compose stack on a Docker Compose host.

Defaults:
  host        172.16.112.232
  user        root          (override with DEPLOY_USER)
  remote dir  ~/work/agent-gov (override with REMOTE_DIR)

Pass localhost, 127.0.0.1, or ::1 to restart on this machine without SSH.

The script preserves the target private docker/.env, uses already-loaded images
with --no-build --pull never, recreates the full stack including Langfuse, and
validates API/UI/Langfuse endpoints.
USAGE
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if (( $# > 1 )); then
  usage >&2
  exit 2
fi

DEPLOY_HOST="${1:-${DEPLOY_HOST:-$DEFAULT_HOST}}"
DEPLOY_USER="${DEPLOY_USER:-root}"
REMOTE_DIR="${REMOTE_DIR:-$DEFAULT_REMOTE_DIR}"
REMOTE="${DEPLOY_USER}@${DEPLOY_HOST}"
LOCAL_TARGET=0
TARGET_LABEL="$REMOTE"
SSH_CONNECT_TIMEOUT="${SSH_CONNECT_TIMEOUT:-10}"
SSH_OPTIONS=(
  -o StrictHostKeyChecking=accept-new
  -o BatchMode=yes
  -o "ConnectTimeout=${SSH_CONNECT_TIMEOUT}"
)

is_local_host() {
  case "$1" in
    localhost|127.0.0.1|::1)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

if is_local_host "$DEPLOY_HOST"; then
  LOCAL_TARGET=1
  TARGET_LABEL="localhost"
fi

log() {
  printf '[restart] %s\n' "$*"
}

die() {
  printf '[restart] ERROR: %s\n' "$*" >&2
  exit 1
}

quote() {
  printf '%q' "$1"
}

target_run() {
  if (( LOCAL_TARGET )); then
    bash -c "$1"
  else
    ssh "${SSH_OPTIONS[@]}" "$REMOTE" "$@"
  fi
}

require_command() {
  local name=$1
  command -v "$name" >/dev/null 2>&1 || die "required command not found: $name"
}

validate_git_origin_project() {
  local remote_url
  local remote_project

  remote_url=$(git -C "$ROOT_DIR" remote get-url origin 2>/dev/null) || die "git origin remote is required"
  remote_url=${remote_url%/}
  remote_project=${remote_url##*/}
  remote_project=${remote_project##*:}
  remote_project=${remote_project%.git}

  if [[ "$remote_project" != "$EXPECTED_GIT_REMOTE_PROJECT" ]]; then
    die "git origin project must be ${EXPECTED_GIT_REMOTE_PROJECT}, got ${remote_project:-<empty>} from $remote_url"
  fi
}

cd "$ROOT_DIR"

REQUIRED_COMMANDS=(git)
if (( ! LOCAL_TARGET )); then
  REQUIRED_COMMANDS+=(ssh)
fi

for command_name in "${REQUIRED_COMMANDS[@]}"; do
  require_command "$command_name"
done

validate_git_origin_project

log "Consumer x Mode x Boundary: target containers use docker/.env, runtime root stays on the target host, secrets stay in private env files"
log "Checking target prerequisites on $TARGET_LABEL"
target_run "command -v python3 >/dev/null && command -v docker >/dev/null && docker compose version >/dev/null"

REMOTE_PATH=$(target_run "REMOTE_DIR=$(quote "$REMOTE_DIR") python3 - <<'PY'
import os

print(os.path.abspath(os.path.expanduser(os.environ['REMOTE_DIR'])))
PY
")
[[ -n "$REMOTE_PATH" ]] || die "failed to resolve target path"

log "Recreating AgentGov services on $TARGET_LABEL:$REMOTE_PATH"
target_run "bash -s -- $(quote "$REMOTE_PATH")" <<'REMOTE_RESTART'
set -euo pipefail
remote_path=$1
cd "$remote_path"

[ -f VERSION ] || { echo "missing VERSION in $remote_path" >&2; exit 1; }
[ -f docker/.env ] || { echo "missing docker/.env in $remote_path" >&2; exit 1; }

version=$(tr -d '[:space:]' < VERSION)
export APP_VERSION="$version"

read_env() {
  local key=$1
  local default=$2
  local value
  value=$(awk -F= -v key="$key" '
    $1 == key {
      sub(/^[^=]*=/, "")
      sub(/[[:space:]]+#.*$/, "")
      gsub(/^"|"$/, "")
      print
      exit
    }
  ' docker/.env 2>/dev/null || true)
  printf '%s' "${value:-$default}"
}

expand_remote_value() {
  local value=$1
  value=${value//\$\{HOME\}/$HOME}
  value=${value//\$HOME/$HOME}
  value=${value/#\~/$HOME}
  printf '%s' "$value"
}

runtime_root=$(expand_remote_value "$(read_env HOST_RUNTIME_VOLUME_ROOT '$HOME/volume-agent-gov')")
container_name_prefix=$(read_env CONTAINER_NAME_PREFIX agent-gov)
echo "Using APP_VERSION=$APP_VERSION"
echo "Using runtime root=$runtime_root"
echo "Using container name prefix=$container_name_prefix"
mkdir -p \
  "$runtime_root/data" \
  "$runtime_root/governor-workspace" \
  "$runtime_root/claude-roots/governor" \
  "$runtime_root/langfuse/postgres" \
  "$runtime_root/langfuse/clickhouse/data" \
  "$runtime_root/langfuse/clickhouse/logs" \
  "$runtime_root/langfuse/redis" \
  "$runtime_root/langfuse/minio"
chmod a+rwx \
  "$runtime_root/langfuse" \
  "$runtime_root/langfuse/postgres" \
  "$runtime_root/langfuse/clickhouse" \
  "$runtime_root/langfuse/clickhouse/data" \
  "$runtime_root/langfuse/clickhouse/logs" \
  "$runtime_root/langfuse/redis" \
  "$runtime_root/langfuse/minio" 2>/dev/null || true

docker compose --env-file docker/.env -f docker/docker-compose.yml --profile langfuse down --remove-orphans || true
leftover_containers=$(docker ps -aq --filter "name=${container_name_prefix}-" || true)
if [ -n "$leftover_containers" ]; then
  docker rm -f $leftover_containers
fi

docker compose --env-file docker/.env -f docker/docker-compose.yml --profile langfuse up -d --force-recreate --no-build --pull never
docker compose --env-file docker/.env -f docker/docker-compose.yml --profile langfuse ps

host_port=$(expand_remote_value "$(read_env HOST_PORT 48080)")
frontend_port=$(expand_remote_value "$(read_env FRONTEND_HOST_PORT 45173)")
langfuse_port=$(expand_remote_value "$(read_env LANGFUSE_HOST_PORT 43000)")

python3 - <<PY
from urllib.error import HTTPError
from urllib.request import Request, urlopen
import time

checks = [
    ("API health", "http://127.0.0.1:${host_port}/health", 60, True),
    ("UI", "http://127.0.0.1:${frontend_port}", 60, False),
    ("Langfuse", "http://127.0.0.1:${langfuse_port}", 90, False),
]

for name, url, attempts, print_body in checks:
    last_error = None
    for _ in range(attempts):
        try:
            request = Request(url, headers={"User-Agent": "agent-gov-restart-smoke"})
            with urlopen(request, timeout=5) as response:
                body = response.read(500)
                print(f"{name} OK: {url} status={response.status}")
                if print_body:
                    print(body.decode("utf-8", "replace"))
                break
        except HTTPError as exc:
            print(f"{name} OK: {url} status={exc.code}")
            break
        except Exception as exc:  # noqa: BLE001 - remote smoke reports final failure text.
            last_error = exc
            time.sleep(2)
    else:
        raise SystemExit(f"{name} failed: {url}: {last_error!r}")
PY
REMOTE_RESTART

log "Restart completed on ${TARGET_LABEL}:${REMOTE_PATH}"
